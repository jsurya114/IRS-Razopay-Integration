<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Payment Confirmed — IRS Learning</title>
</head>
<body style="margin:0; padding:0; background-color:#f4f4f4; font-family: Arial, sans-serif;">
  <table width="100%" cellpadding="0" cellspacing="0" style="background-color:#f4f4f4; padding: 30px 0;">
    <tr>
      <td align="center">
        <table width="600" cellpadding="0" cellspacing="0" style="background-color:#ffffff; border-radius:8px; overflow:hidden; box-shadow: 0 2px 8px rgba(0,0,0,0.08);">

          <!-- Header -->
          <tr>
            <td style="background-color:#1a56db; padding: 28px 40px; text-align:center;">
              <h1 style="margin:0; color:#ffffff; font-size:22px; font-weight:700; letter-spacing:0.5px;">IRS Learning</h1>
            </td>
          </tr>

          <!-- Body -->
          <tr>
            <td style="padding: 36px 40px;">
              <p style="margin:0 0 16px 0; font-size:16px; color:#333333;">Hi <strong><%= name %></strong>,</p>
              <p style="margin:0 0 24px 0; font-size:15px; color:#555555; line-height:1.6;">
                Your payment of <strong style="color:#1a56db;">₹<%= amount %></strong> has been received successfully. Thank you for enrolling with IRS Learning!
              </p>

              <!-- Payment Details Table -->
              <table width="100%" cellpadding="0" cellspacing="0" style="border: 1px solid #e0e0e0; border-radius:6px; overflow:hidden; margin-bottom:24px;">
                <tr style="background-color:#f8f9fa;">
                  <td colspan="2" style="padding:12px 16px; font-size:13px; font-weight:700; color:#666666; text-transform:uppercase; letter-spacing:0.5px; border-bottom:1px solid #e0e0e0;">
                    Payment Details
                  </td>
                </tr>
                <tr style="border-bottom:1px solid #f0f0f0;">
                  <td style="padding:11px 16px; font-size:14px; color:#666666; width:40%;">Order ID</td>
                  <td style="padding:11px 16px; font-size:14px; color:#333333; font-weight:600;"><%= orderId %></td>
                </tr>
                <tr style="background-color:#fafafa; border-bottom:1px solid #f0f0f0;">
                  <td style="padding:11px 16px; font-size:14px; color:#666666;">Payment ID</td>
                  <td style="padding:11px 16px; font-size:14px; color:#333333; font-weight:600;"><%= paymentId %></td>
                </tr>
                <tr style="border-bottom:1px solid #f0f0f0;">
                  <td style="padding:11px 16px; font-size:14px; color:#666666;">Amount Paid</td>
                  <td style="padding:11px 16px; font-size:14px; color:#1a56db; font-weight:700;">₹<%= amount %></td>
                </tr>
                <tr style="background-color:#fafafa;">
                  <td style="padding:11px 16px; font-size:14px; color:#666666;">Date</td>
                  <td style="padding:11px 16px; font-size:14px; color:#333333;"><%= date %></td>
                </tr>
              </table>

              <p style="margin:0 0 8px 0; font-size:15px; color:#555555; line-height:1.6;">
                Your invoice is attached to this email. Please keep it for your records.
              </p>
              <p style="margin:0; font-size:15px; color:#555555; line-height:1.6;">
                If you have any questions, feel free to reach out to us at <a href="mailto:enquiry@irsgroup.in" style="color:#1a56db; text-decoration:none;">enquiry@irsgroup.in</a>.
              </p>
            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td style="background-color:#f8f9fa; padding: 20px 40px; text-align:center; border-top:1px solid #e0e0e0;">
              <p style="margin:0; font-size:13px; color:#999999;">IRS Learning | <a href="mailto:enquiry@irsgroup.in" style="color:#1a56db; text-decoration:none;">enquiry@irsgroup.in</a></p>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>
</body>
</html>
