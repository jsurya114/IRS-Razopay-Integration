    max-height:100vh; max-height:100dvh; overflow-y:auto; -webkit-overflow-scrolling:touch; overscroll-behavior:contain; }
  .ws-modal-x{ position:absolute; top:13px; right:13px; width:32px; height:32px; border:0; padding:0; cursor:pointer;
