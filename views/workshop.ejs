<!-- ============ ANALYTICS: attribution capture + funnel events ============ -->
<script>
(function(){
  // Attribution — capture UTM/referrer off the landing URL (last-touch wins),
  // persisted so it survives reloads and is available at checkout. /api/create-order
  // reads it back → stores it on the Razorpay order → attaches it to the paid seat.
  try{
    var params = new URLSearchParams(location.search);
    var referrer = (document.referrer || '').slice(0,300);
    var utmKeys = ['utm_source','utm_medium','utm_campaign','utm_content','utm_term'];
    var incoming = {}, hasUtm = false;
    utmKeys.forEach(function(k){ var val = params.get(k); if(val){ incoming[k] = val.slice(0,200); hasUtm = true; } });
    // Untagged Meta ad click: Meta appends fbclid to every ad click, but the ad's
    // destination URL carried no utm_* tags. Synthesize a source so the seat reads as
    // paid social in admin instead of looking identical to direct/organic traffic.
    // (Meta still attributes it via the _fbc cookie regardless — this is only for our
    // own dashboard. fbclid can't tell FB from IG, so default to 'meta' unless the
    // referrer leaks the network; 'untagged' campaign flags it as inferred, not tagged.)
    if(!hasUtm && params.get('fbclid')){
      incoming.utm_source = /instagram/i.test(referrer) ? 'ig' : /facebook/i.test(referrer) ? 'fb' : 'meta';
      incoming.utm_medium = 'paid_social';
      incoming.utm_campaign = 'untagged';
      hasUtm = true;
    }
    if(hasUtm){
      incoming.referrer = referrer;
      try{ localStorage.setItem('vz_attr', JSON.stringify(incoming)); }catch(_){}
    }
  }catch(_){}

  // Funnel events → Meta (fbq custom). PageView already fires from the base
  // pixel; these capture the on-page journey between it and checkout. Clarity
  // covers scroll/heatmaps natively, so nothing is wired to it here.
  function ev(fbName, params){
    try{ if(window.fbq && fbName) window.fbq('trackCustom', fbName, params || {}); }catch(_){}
  }

  // Scroll depth — each milestone fires once.
  var marks = [25,50,75,90], fired = {};
  function onScroll(){
    var el = document.documentElement, body = document.body;
    var scrollTop = window.pageYOffset || el.scrollTop || body.scrollTop || 0;
    var height = (el.scrollHeight || body.scrollHeight) - window.innerHeight;
    if(height <= 0) return;
    var pct = Math.min(100, Math.round((scrollTop / height) * 100));
    marks.forEach(function(m){ if(pct >= m && !fired[m]){ fired[m] = true; ev('ScrollDepth',{percent:m}); } });
    if(fired[90]) window.removeEventListener('scroll', onScroll);
  }
  window.addEventListener('scroll', onScroll, {passive:true});

  // Reached the registration form (scrolled into view).
  var formEl = document.getElementById('ws-form');
  if(formEl && 'IntersectionObserver' in window){
    var io = new IntersectionObserver(function(entries){
      entries.forEach(function(e){ if(e.isIntersecting){ ev('ReachedForm',{}); io.disconnect(); } });
    }, {threshold:0.4});
    io.observe(formEl);
  }

  // Form start — first focus on any field (intent, before payment).
  var started = false;
  ['ws-name','ws-email','ws-phone'].forEach(function(id){
    var f = document.getElementById(id);
    if(!f) return;
    f.addEventListener('focus', function(){ if(started) return; started = true; ev('FormStart',{}); });
  });
})();
</script>

<!-- ============ PAYMENT: Razorpay checkout ============ -->
<script src="https://checkout.razorpay.com/v1/checkout.js"></script>
<script>
(function(){
  var GCAL_URL = "https://calendar.google.com/calendar/render?action=TEMPLATE"
    + "&text=" + encodeURIComponent("PTE Score 79+ Masterclass — IRS Learning")
    + "&dates=20260711T043000Z/20260711T083000Z"
    + "&details=" + encodeURIComponent("Your live 4-hour PTE masterclass. The joining link will be emailed to you.")
    + "&location=" + encodeURIComponent("Online");
  var ICS = [
    "BEGIN:VCALENDAR","VERSION:2.0","PRODID:-//IRS Learning//PTE Masterclass//EN","CALSCALE:GREGORIAN",
    "BEGIN:VEVENT","UID:pte-masterclass-2026-07-11@verbisedu.com","DTSTAMP:20260625T000000Z",
    "DTSTART:20260711T043000Z","DTEND:20260711T083000Z",
    "SUMMARY:PTE Score 79+ Masterclass — IRS Learning",
    "DESCRIPTION:Your live 4-hour PTE masterclass. The joining link will be emailed to you.",
    "LOCATION:Online","END:VEVENT","END:VCALENDAR"
  ].join("\r\n");

  var form = document.getElementById('ws-form');
  if(!form) return;
  var btn = document.getElementById('ws-pay');
  var errEl = document.getElementById('ws-err');
  var nameEl = document.getElementById('ws-name');
  var emailEl = document.getElementById('ws-email');
  var phoneEl = document.getElementById('ws-phone');
  var bumpEl = document.getElementById('bump');
  var modal = document.getElementById('ws-checkout');

  // Mock-pack order bump: reflect the +₹590 in the modal summary + pay button.
  if(bumpEl){
    var coNow = document.getElementById('ws-co-now');
    var coWas = document.getElementById('ws-co-was');
    var payAmt = document.getElementById('ws-pay-amt');
    bumpEl.addEventListener('change', function(){
      var on = bumpEl.checked;
      if(coNow) coNow.textContent = on ? '₹1,179' : '₹589';
      if(coWas) coWas.textContent = on ? '₹4,998' : '₹2,999';
      if(payAmt) payAmt.textContent = on ? '₹1,179' : '₹589';
    });
  }
  var successOv = document.getElementById('ws-success');

  function lockScroll(on){ document.documentElement.style.overflow = on ? 'hidden' : ''; }

  // The on-screen keyboard overlays the page without resizing it (iOS + Android
  // Chrome 108+), so a bottom-anchored sheet ends up half-hidden behind it —
  // tapping a covered field (e.g. phone, below email) misses and dismisses the
  // keyboard. Track the visual viewport and keep the whole sheet above the keyboard.
  var vv = window.visualViewport;
  var modalCard = modal.querySelector('.ws-modal-card');
  function syncSheet(){
    if(!vv || !modal.classList.contains('show')) return;
    modal.style.top = vv.offsetTop + 'px';
    modal.style.height = vv.height + 'px';
    modalCard.style.maxHeight = vv.height + 'px';
  }
  function resetSheet(){ modal.style.top = ''; modal.style.height = ''; modalCard.style.maxHeight = ''; }
  var vvRaf = 0;
  function queueSync(){ if(vvRaf) return; vvRaf = requestAnimationFrame(function(){ vvRaf = 0; syncSheet(); }); }
  if(vv){ vv.addEventListener('resize', queueSync); vv.addEventListener('scroll', queueSync); }

  // Picking an autofill/QuickType suggestion can dismiss the keyboard at the OS
  // level. When the email lands in one shot (suggestion tap / paste / autofill),
  // advance focus to the phone field inside the same gesture so the keyboard
  // stays up on the number pad instead of stranding the buyer mid-form.
  function advanceToPhone(){
    try{ phoneEl.focus(); }catch(_){}
    phoneEl.classList.remove('nudge'); void phoneEl.offsetWidth; phoneEl.classList.add('nudge');
  }
  var emailPrevLen = 0;
  emailEl.addEventListener('input', function(e){
    var len = emailEl.value.length;
    var jumped = (len - emailPrevLen) >= 4;   // value arrived in one shot, however the OS reports it
    emailPrevLen = len;
    var oneShot = !e.inputType || e.inputType === 'insertReplacementText' || e.inputType === 'insertFromPaste' || jumped;
    if(oneShot && validEmail(emailEl.value.trim()) && !phoneEl.value) advanceToPhone();
  });
  // Re-picking the same suggestion fires no input event (value unchanged), but the
  // keyboard still closes. Catch the keyboard-close itself: if it collapses while
  // a completed email is focused and phone is empty, the buyer's next stop is phone.
  var vvPrevH = vv ? vv.height : 0;
  if(vv) vv.addEventListener('resize', function(){
    var grew = vv.height - vvPrevH; vvPrevH = vv.height;
    if(grew > 150 && modal.classList.contains('show') && document.activeElement === emailEl
       && validEmail(emailEl.value.trim()) && !phoneEl.value) advanceToPhone();
  });

  function openCheckout(){ clearErr(); loading(false); modal.classList.add('show'); lockScroll(true); syncSheet(); setTimeout(function(){ try{ nameEl.focus(); }catch(_){} }, 60); }
  function closeCheckout(){ modal.classList.remove('show'); lockScroll(false); resetSheet(); }

  // Any "Claim my seat" CTA (they all point to #book) or a [data-checkout] button opens the focused checkout.
  document.addEventListener('click', function(e){
    var t = e.target.closest && e.target.closest('a[href="#book"], [data-checkout]');
    if(!t) return;
    e.preventDefault();
    openCheckout();
  });
  document.getElementById('ws-co-close').addEventListener('click', closeCheckout);
  modal.addEventListener('click', function(e){
    // Desktop only: on mobile the sheet shifts as the keyboard opens/closes, so a
    // backdrop tap is usually a mis-aimed field tap — closing would wipe the form.
    if(e.target === modal && matchMedia('(min-width:561px)').matches) closeCheckout();
  });

  function showErr(m){ errEl.textContent = m; errEl.hidden = false; }
  // Charged-but-unverified path: give the buyer a real support channel, with the
  // payment id prefilled so the team can confirm the seat from the chat alone.
  function showErrWa(m, pid){
    errEl.textContent = m + ' ';
    var a = document.createElement('a');
    a.href = 'https://wa.me/919945328060?text=' + encodeURIComponent("Hi! I paid for the PTE Masterclass but didn't get a confirmation." + (pid ? ' Payment ID: ' + pid : ''));
    a.target = '_blank'; a.rel = 'noopener';
    a.textContent = 'Message us on WhatsApp';
    errEl.appendChild(a);
    errEl.hidden = false;
  }
  function clearErr(){ errEl.hidden = true; }
  function loading(on){ btn.disabled = on; }
  function validEmail(v){ return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v); }
  function validPhone(v){ return v.replace(/\D/g,'').length >= 10; }
  function mark(el, bad){ el.classList.toggle('err', bad); }

  function showSuccess(paymentId, accessToken){
    modal.classList.remove('show');
    var portalEl = document.getElementById('ws-portal');
    var pEl = document.getElementById('ws-success-p');
    if(accessToken){
      portalEl.href = '/workshop/live?t=' + encodeURIComponent(accessToken);
      portalEl.style.display = 'block';
      if(pEl) pEl.textContent = "You're in! 🎉 Enter the classroom below — we've also emailed your private link (it's tied to your seat, so keep it to yourself).";
    } else {
      portalEl.style.display = 'none';
      if(pEl) pEl.textContent = "You're in! 🎉 Your private classroom link is on its way to your email — that's where you'll join the live class.";
    }
    document.getElementById('ws-cal').href = GCAL_URL;
    document.getElementById('ws-ics').href = "data:text/calendar;charset=utf-8," + encodeURIComponent(ICS);
    if(paymentId) document.getElementById('ws-pid').textContent = "Payment ID: " + paymentId;
    successOv.classList.add('show');
    lockScroll(true);
  }

  form.addEventListener('submit', async function(e){
    e.preventDefault();
    clearErr();
    var name = nameEl.value.trim(), email = emailEl.value.trim(), phone = phoneEl.value.trim();
    mark(nameEl, !name); mark(emailEl, !validEmail(email)); mark(phoneEl, !validPhone(phone));
    if(!name || !validEmail(email) || !validPhone(phone)){ showErr("Please enter a valid name, email and phone number."); return; }
    if(typeof Razorpay === 'undefined'){ showErr("Payment couldn't load — check your connection and try again."); return; }

    var mockPack = !!(bumpEl && bumpEl.checked);

    // Attribution captured on landing (utm_*/referrer) → rides along to the order.
    var attr = {};
    try{ attr = JSON.parse(localStorage.getItem('vz_attr') || 'null') || {}; }catch(_){}

    loading(true);
    try{
      var res = await fetch('api/create-order', {
        method:'POST', headers:{'Content-Type':'application/json'},
        body: JSON.stringify({ name: name, email: email, phone: phone, mockPack: mockPack, utm: attr })
      });
      var order = await res.json();
      if(!res.ok) throw new Error((order && order.error) || "Could not start the payment.");

      var rzp = new Razorpay({
        key: order.keyId,
        order_id: order.orderId,
        amount: order.amount,
        currency: order.currency,
        name: "IRS Learning",
        description: mockPack ? "PTE Masterclass + Mock Test Pack" : "PTE Score 79+ Masterclass",
        image: "/logo-icon.png",
        prefill: { name: name, email: email, contact: phone, method: 'upi' },
        // UPI-first: prefill.method:'upi' opens straight on UPI, and hide_topbar removes
        // the method/back bar so the buyer lands directly on the UPI app list
        // (GPay/PhonePe/Paytm one-tap intent) — no "select UPI" step, no switching to cards.
        // Desktop (no intent) auto-falls back to a UPI QR.
        theme: { color: "#FBBD29", hide_topbar: true },
        handler: async function(resp){
          try{
            var vres = await fetch('api/verify-payment', {
              method:'POST', headers:{'Content-Type':'application/json'},
              body: JSON.stringify({
                razorpay_order_id: resp.razorpay_order_id,
                razorpay_payment_id: resp.razorpay_payment_id,
                razorpay_signature: resp.razorpay_signature,
                name: name, email: email, phone: phone, mockPack: mockPack
              })
            });
            var v = await vres.json();
            if(vres.ok && v.success){
              // Purchase — eventID shared with the server (Conversions API) so Meta dedups to one.
              try{ if(window.fbq) fbq('track','Purchase', { value: order.amount/100, currency: order.currency || 'INR', content_name: mockPack ? 'PTE Masterclass + Mock Test Pack' : 'PTE Score 79+ Masterclass' }, { eventID: 'purchase_' + resp.razorpay_payment_id }); }catch(_){}
              showSuccess(resp.razorpay_payment_id, v.accessToken);
            }
            else { showErrWa("We couldn't verify the payment. If you were charged, we'll confirm your seat —", resp.razorpay_payment_id); loading(false); }
          }catch(_){ showErrWa("Verification failed. If you were charged, we'll confirm your seat —", resp.razorpay_payment_id); loading(false); }
        },
        modal: { ondismiss: function(){ loading(false); } }
      });
      rzp.on('payment.failed', function(){ showErr("Payment failed or was declined. Please try again."); loading(false); });
      try{ if(window.fbq) fbq('track','InitiateCheckout', { value: order.amount/100, currency: order.currency || 'INR' }); }catch(_){}
      rzp.open();
    }catch(err){
      showErr((err && err.message) || "Something went wrong. Please try again.");
      loading(false);
    }
  });

  successOv.addEventListener('click', function(e){ if(e.target === successOv){ successOv.classList.remove('show'); lockScroll(false); } });
  document.addEventListener('keydown', function(e){
    if(e.key !== 'Escape') return;
    if(modal.classList.contains('show')) closeCheckout();
    else if(successOv.classList.contains('show')){ successOv.classList.remove('show'); lockScroll(false); }
  });

})();
</script>
</body>
