<script>
(function(){
  document.documentElement.classList.add('js');
  var reduce = matchMedia && matchMedia('(prefers-reduced-motion: reduce)').matches;

  /* —— count-ups —— */
  function runCount(el){
    if(el.dataset.done) return; el.dataset.done='1';
    var m=String(el.textContent).match(/^(\D*)([\d,]+)(.*)$/); if(!m) return;
    var pre=m[1], num=parseInt(m[2].replace(/,/g,''),10), suf=m[3];
    if(reduce){ el.textContent=pre+num.toLocaleString('en-IN')+suf; return; }
    var dur=1100,t0=null;
    function f(t){ if(!t0)t0=t; var p=Math.min((t-t0)/dur,1); var e=1-Math.pow(1-p,3);
      el.textContent=pre+Math.round(num*e).toLocaleString('en-IN')+suf; if(p<1)requestAnimationFrame(f); }
    requestAnimationFrame(f);
  }

  /* —— reveal via IntersectionObserver —— */
  var io = ('IntersectionObserver' in window) ? new IntersectionObserver(function(es){
    es.forEach(function(en){ if(en.isIntersecting){ var el=en.target; el.classList.add('in');
      if(el.classList.contains('count')) runCount(el);
      el.querySelectorAll && el.querySelectorAll('.count').forEach(runCount);
      io.unobserve(el); } });
  }, {rootMargin:'0px 0px -8% 0px', threshold:0.12}) : null;
  function watch(sel){ document.querySelectorAll(sel).forEach(function(el){ if(io) io.observe(el); else { el.classList.add('in'); el.querySelectorAll&&el.querySelectorAll('.count').forEach(runCount);} }); }
  /* the hero (incl. the enroll card, which sits below the first mobile fold)
     renders instantly — a scroll-gated fade there reads as lazy-loading */
  document.querySelectorAll('.hero .rev').forEach(function(el){ el.classList.add('in'); });
  watch('.rev'); watch('.count-fill'); watch('.mcard'); watch('.count');

  /* —— sticky + nav countdown —— */
  var sticky=document.getElementById('sticky'), navcd=document.getElementById('navcd');
  var navEl=document.querySelector('.nav');
  var hero=document.querySelector('.hero'), booking=document.getElementById('book');
  function onScroll(){
    var y=window.scrollY||document.documentElement.scrollTop, past=hero?hero.offsetHeight*0.7:600;
    var bookTop = booking?booking.getBoundingClientRect().top:9999, inBooking = bookTop < window.innerHeight && bookTop > -booking.offsetHeight;
    if(navEl) navEl.classList.toggle('scrolled', y>12);
    sticky.classList.toggle('show', y>past && !inBooking);
    navcd.classList.toggle('show', y>past);
  }
  onScroll(); window.addEventListener('scroll', onScroll, {passive:true}); window.addEventListener('resize', onScroll);

  /* —— order bump price-toggle lives in the payment script below (the modal
     markup, incl. #bump, is parsed after this block, so it can't bind here) —— */

  /* —— countdown to workshop start: Tue 11 Aug 2026, 10:00 IST —— */
  var target = new Date('2026-08-11T10:00:00+05:30').getTime();
  function pad(n){ return String(n).padStart(2,'0'); }
  function tick(){
    var diff=target-Date.now(); if(diff<0)diff=0;
    var d=Math.floor(diff/864e5),h=Math.floor(diff%864e5/36e5),m=Math.floor(diff%36e5/6e4),s=Math.floor(diff%6e4/1e3);
    document.querySelectorAll('[data-countdown]').forEach(function(b){
      var q=function(k){return b.querySelector('[data-'+k+']')};
      if(q('d'))q('d').textContent=pad(d); if(q('h'))q('h').textContent=pad(h); if(q('m'))q('m').textContent=pad(m); if(q('s'))q('s').textContent=pad(s);
    });
    document.querySelectorAll('[data-starts-short]').forEach(function(el){ el.textContent = d>0 ? d+'d '+h+'h' : h+'h '+m+'m'; });
  }
  tick(); setInterval(tick,1000);

  /* —— static seat counter: depletes toward the workshop date (one prop; swap to live count later) —— */
  (function(){
    var CAP=100, FLOOR=15, START=53, WINDOW=11; // ~START seats at WINDOW days out → FLOOR at 0
    var daysLeft = Math.max(0, Math.ceil((target-Date.now())/864e5));
    var seats = Math.round(FLOOR + (Math.min(daysLeft,WINDOW)/WINDOW)*(START-FLOOR));
    seats = Math.max(FLOOR, Math.min(START, seats));
    document.querySelectorAll('[data-seats]').forEach(function(el){ el.textContent=seats; });
    requestAnimationFrame(function(){ document.querySelectorAll('.seatfill').forEach(function(fill){ fill.style.width=((CAP-seats)/CAP*100).toFixed(0)+'%'; }); });
  })();

  /* —— target-score micro-quiz —— */
  (function(){
    var steps=document.querySelectorAll('.qstep'); var done=0, total=steps.length, out=document.getElementById('qout');
    steps.forEach(function(st){ st.querySelectorAll('.qopt').forEach(function(b){
      b.addEventListener('click', function(){
        var already=st.querySelector('.qopt.sel'); if(!already) done++;
        st.querySelectorAll('.qopt').forEach(function(o){o.classList.remove('sel');});
        b.classList.add('sel');
        if(done>=total && out) out.classList.add('show');
      });
    });});
  })();

  /* —— video showcase: click / keyboard to play —— */
  document.querySelectorAll('.vid').forEach(function(card){
    function playVid(e){
      var v=card.querySelector('video'); if(!v) return;
      if (e && e.target === v && v.hasAttribute('controls')) return;
      if(v.paused){ v.setAttribute('controls',''); var p=v.play(); if(p&&p.catch)p.catch(function(){}); card.classList.add('playing'); }
    }
    card.addEventListener('click', playVid);
    card.addEventListener('keydown', function(e){ if(e.key==='Enter'||e.key===' '){ e.preventDefault(); playVid(e); } });
  });

  /* —— scorecard lightbox (tap to enlarge & verify) —— */
  (function(){
    var lb=document.createElement('div'); lb.className='lightbox';
    var im=document.createElement('img'); lb.appendChild(im); document.body.appendChild(lb);
    document.querySelectorAll('.scw').forEach(function(fig){
      var open=function(){ im.src=fig.getAttribute('data-full')||''; lb.classList.add('open'); };
      fig.addEventListener('click', open);
      fig.addEventListener('keydown', function(e){ if(e.key==='Enter'||e.key===' '){ e.preventDefault(); open(); } });
    });
    lb.addEventListener('click', function(){ lb.classList.remove('open'); });
    document.addEventListener('keydown', function(e){ if(e.key==='Escape') lb.classList.remove('open'); });
  })();
})();
</script>
<script id="reader-anim">
/* Motion graphic: the PTE engine "scoring" a spoken answer. Plays when scrolled into view,
   ticking the band up as each pattern is detected. Default DOM = finished state (graceful). */
(function(){
  var reader = document.querySelector('.reader'); if(!reader) return;
  var marks  = [].slice.call(reader.querySelectorAll('.reader-text mark'));
  var tags   = [].slice.call(reader.querySelectorAll('.reader-tags .rt'));
  var num    = reader.querySelector('.rv-num');
  var status = reader.querySelector('.reader-status');
  var STEPS  = [41, 58, 70, 79];      // illustrative band as each marker lands
  var FINAL  = 'scored on patterns';
  var SCAN   = 'scanning…';
  var timers = [], raf = null, running = false;

  function clearAll(){ timers.forEach(clearTimeout); timers = []; if(raf) cancelAnimationFrame(raf); raf = null; }
  function tick(from, to, ms){
    var s = null;
    (function frame(t){ if(s===null) s=t; var p = Math.min(1,(t-s)/ms);
      if(num) num.textContent = Math.round(from + (to-from)*p);
      if(p<1) raf = requestAnimationFrame(frame); })(performance.now());
  }
  function toStart(){ clearAll(); marks.forEach(function(m){ m.classList.add('pre'); });
    tags.forEach(function(t){ t.classList.add('pre'); }); if(num) num.textContent='0'; if(status) status.textContent=SCAN; }
  function toEnd(){ clearAll(); marks.forEach(function(m){ m.classList.remove('pre'); });
    tags.forEach(function(t){ t.classList.remove('pre'); }); if(num) num.textContent='79'; if(status) status.textContent=FINAL; running=false; }
  function play(){
    if(running) return; running = true; toStart();
    var t = 700;
    marks.forEach(function(m, i){
      timers.push(setTimeout(function(){
        m.classList.remove('pre');
        if(tags[i]) tags[i].classList.remove('pre');
        tick(i ? STEPS[i-1] : 0, STEPS[i], 480);
      }, t));
      t += 850;
    });
    timers.push(setTimeout(function(){ if(status) status.textContent = FINAL; running = false; }, t + 100));
  }

  if(matchMedia('(prefers-reduced-motion: reduce)').matches) return; // leave finished default

  var io = new IntersectionObserver(function(entries){
    var e = entries[0];
    if(e.isIntersecting) play(); else { clearAll(); running=false; toEnd(); }
  }, { threshold: 0.5 });
  io.observe(reader);
})();
</script>

