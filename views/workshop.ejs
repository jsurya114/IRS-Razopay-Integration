      </label>
      <button class="btn btn-primary btn-lg btn-block" id="ws-pay" type="submit">Pay <span id="ws-pay-amt">₹589</span> · Confirm seat<svg class="ic" viewBox="0 0 24 24"><path d="M5 12h14M13 6l6 6-6 6"/></svg></button>
      <p class="ws-err" id="ws-err" hidden></p>
    </form>
    <p class="ws-co-trust">Secured by Razorpay · GST included · No spam, ever · Full refund before class starts</p>
