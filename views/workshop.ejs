  .ft-col ul{ list-style:none; margin:0; padding:0; display:grid; gap:11px; }
  .ft-col a{ color:rgba(247,245,240,.5); font-size:13.5px; font-weight:500; text-decoration:none; transition:color .2s var(--ease-out); }
  .ft-col a:hover{ color:#107a2f; }
  .ft-contact li{ display:flex; align-items:flex-start; gap:10px; }
  .ft-contact .ic{ width:14px; height:14px; color:#107a2f; margin-top:2px; }
  .ft-contact span{ color:rgba(247,245,240,.5); font-size:13.5px; font-weight:500; line-height:1.5; }
  .ft-social{ display:flex; gap:10px; }
  .ft-social a{ width:40px; height:40px; border-radius:10px; background:rgba(247,245,240,.06); display:flex; align-items:center; justify-content:center; transition:background .2s var(--ease-out); }
  .ft-social a:hover{ background:rgba(251,189,41,.2); }
  .ft-social svg{ width:16px; height:16px; fill:rgba(247,245,240,.6); transition:fill .2s var(--ease-out); }
  .ft-social a:hover svg{ fill:#107a2f; }
  .ft-bottom{ margin-top:52px; padding-top:30px; border-top:1px solid rgba(247,245,240,.08); display:flex; align-items:center; justify-content:space-between; gap:16px; flex-wrap:wrap; }
  .ft-bottom p{ color:rgba(247,245,240,.32); font-size:13px; margin:0; }
  .ft-legal{ display:flex; gap:24px; }
  .ft-legal a{ color:rgba(247,245,240,.32); font-size:13px; text-decoration:none; transition:color .2s var(--ease-out); }
  .ft-legal a:hover{ color:rgba(247,245,240,.6); }
  @media (max-width:860px){ .ft-grid{ grid-template-columns:1fr 1fr; gap:34px; } .ft-bottom{ flex-direction:column; align-items:flex-start; } }
  @media (max-width:520px){ .ft-grid{ grid-template-columns:1fr; } }

  /* —— STICKY BAR —— */
  .sticky{ position:fixed; left:0; right:0; bottom:0; z-index:50; background:rgba(247,245,240,.96);
    backdrop-filter:blur(16px); -webkit-backdrop-filter:blur(16px); border-top:1px solid var(--line);
    box-shadow:0 -8px 28px -14px rgba(14,72,82,.25); transform:translateY(130%); transition:transform .45s var(--ease-out); }
  .sticky.show{ transform:none; }
  .sk-inner{ max-width:1140px; margin:0 auto; padding:11px 16px calc(11px + env(safe-area-inset-bottom)); display:flex; align-items:center; gap:14px; }
  .sk-cd{ display:none; align-items:center; gap:8px; font-family:var(--font-mono); font-size:12.5px; color:var(--fg-2); }
  .sk-cd b{ color:var(--teal); } .sk-cd .ic{ width:14px; height:14px; color:#107a2f; }
  .sk-price{ font-family:var(--font-mono); font-weight:700; font-size:16px; color:var(--teal); white-space:nowrap; }
  .sk-bp{ display:none; }
  .sk-g{ margin-left:auto; display:inline-flex; padding:6px 11px; border-radius:11px; gap:8px; }
  .sk-g .gbadge-g{ width:19px; height:19px; }
  .sk-g .gbadge-top b{ font-size:14px; }
  .sk-g .gstars{ font-size:10px; }
  .sk-g .gbadge-sub{ font-size:10.5px; }
  @media (min-width:560px){ .sk-cd{ display:flex; } }
  @media (max-width:640px){
    .sk-inner{ flex-wrap:wrap; gap:9px; justify-content:center; }
    .sk-price{ display:none; }
    .sk-bp{ display:inline; }
    .sk-g{ margin:0; padding:0; background:none; border:0; box-shadow:none; gap:7px; }
    .sk-g .gbadge-body{ flex-direction:row; align-items:center; gap:7px; }
    .sk-g .gbadge-sub{ font-size:11.5px; }
    .sticky .btn{ flex:1 0 100%; margin-left:0; justify-content:center; }
  }
  .pad{ height:78px; }

  /* —— RESPONSIVE —— */
  @media (min-width:640px){
    .alg-grid{ grid-template-columns:repeat(3,1fr); }
    .steps{ grid-template-columns:repeat(3,1fr); }
    .res-grid{ grid-template-columns:repeat(3,1fr); }
    .vids{ grid-template-columns:repeat(3,1fr); gap:18px; align-items:start; }
  }
  @media (min-width:880px){
    .sec{ padding:60px 0; }
    .hero{ padding:30px 0 0; }
    .hero-inner{ grid-template-columns:1.05fr .92fr; gap:48px; }
    .booking{ grid-template-columns:.9fr 1.1fr; align-items:start; }
    .report-grid{ grid-template-columns:repeat(4,1fr); }
  }

  /* —— workshop checkout form —— */
  .ws-form{ display:grid; gap:10px; margin-top:4px; }
  .ws-in{ width:100%; font-family:inherit; font-size:16px; color:var(--teal); background:var(--white);
    border:1px solid var(--line); border-radius:12px; padding:13px 15px; outline:none;
    transition:border-color .2s var(--ease-out), box-shadow .2s var(--ease-out); }
  .ws-in::placeholder{ color:var(--fg-3); }
  .ws-in:focus{ border-color:#107a2f; box-shadow:0 0 0 3px var(--gold-soft); }
  .ws-in.err{ border-color:#d23f3f; box-shadow:0 0 0 3px rgba(210,63,63,.12); }
  @keyframes ws-nudge{ 0%,100%{ box-shadow:0 0 0 0 rgba(251,189,41,0); } 40%{ box-shadow:0 0 0 4px var(--gold-soft); border-color:#107a2f; } }
  .ws-in.nudge{ animation:ws-nudge .8s var(--ease-out) 2; }
  @media (prefers-reduced-motion:reduce){ .ws-in.nudge{ animation:none; border-color:#107a2f; } }
  .ws-form .btn[disabled]{ opacity:.6; pointer-events:none; }
  .ws-err{ margin:2px 0 0; font-size:12.5px; color:#c23434; text-align:center; }
  .ws-err a{ color:#c23434; font-weight:700; text-decoration:underline; text-underline-offset:2px; }
  details.q .a a{ color:#107a2f; font-weight:600; text-decoration:underline; text-underline-offset:2px; }

  /* —— checkout modal (centered dialog · bottom-sheet on mobile) —— */
  .ws-modal{ position:fixed; inset:0; z-index:115; display:none; align-items:center; justify-content:center;
    padding:20px; background:rgba(6,30,35,.5); backdrop-filter:blur(5px); -webkit-backdrop-filter:blur(5px); }
  .ws-modal.show{ display:flex; }
  .ws-modal-card{ position:relative; width:100%; max-width:420px; background:var(--white); border-radius:22px;
    padding:26px 24px 20px; box-shadow:0 40px 90px -30px rgba(6,30,35,.6);
    /* keyboard-safe: card can never outgrow the (keyboard-shrunk) viewport */
    max-height:100vh; max-height:100dvh; overflow-y:auto; -webkit-overflow-scrolling:touch; overscroll-behavior:contain; }
  .ws-modal-x{ position:absolute; top:13px; right:13px; width:32px; height:32px; border:0; padding:0; cursor:pointer;
    background:var(--paper-warm); border-radius:999px; color:var(--fg-2); display:flex; align-items:center; justify-content:center; }
  .ws-modal-x svg{ width:16px; height:16px; }
  .ws-co-head{ margin-bottom:16px; padding-right:34px; }
  .ws-co-head h3{ font-family:var(--font-sans); font-size:21px; font-weight:800; color:var(--teal); margin:0 0 4px; letter-spacing:-0.01em; }
  .ws-co-sum{ font-size:13px; color:var(--fg-2); margin:0; }
  .ws-co-sum b{ color:var(--teal); font-weight:700; } .ws-co-sum s{ color:var(--fg-3); margin-left:5px; }
  .ws-co-trust{ margin:13px 0 0; font-size:11.5px; color:var(--fg-3); text-align:center; }
  @media (max-width:560px){
    .ws-modal{ align-items:flex-end; padding:0; }
    .ws-modal-card{ max-width:none; border-radius:20px 20px 0 0; padding:24px 20px calc(20px + env(safe-area-inset-bottom)); animation:ws-sheet .28s var(--ease-out); }
    @keyframes ws-sheet{ from{ transform:translateY(100%); } to{ transform:translateY(0); } }
  }

  /* —— payment success overlay —— */
  .ws-success{ position:fixed; inset:0; z-index:120; display:none; align-items:center; justify-content:center;
    padding:20px; background:rgba(6,30,35,.55); backdrop-filter:blur(6px); -webkit-backdrop-filter:blur(6px); }
  .ws-success.show{ display:flex; }
  .ws-card{ width:100%; max-width:440px; background:var(--white); border-radius:22px; padding:30px 26px;
    box-shadow:0 40px 90px -30px rgba(6,30,35,.6); text-align:center; }
  .ws-check{ width:60px; height:60px; border-radius:999px; margin:0 auto 16px; display:flex; align-items:center; justify-content:center;
    background:var(--gold-soft); color:#107a2f; }
  .ws-check svg{ width:30px; height:30px; }
  .ws-card h3{ font-family:var(--font-sans); font-size:23px; font-weight:800; color:var(--teal); margin:0 0 6px; letter-spacing:-0.01em; }
  .ws-card > p{ font-size:14px; color:var(--fg-2); line-height:1.6; margin:0 0 18px; }
  .ws-meta{ background:var(--paper-warm); border:1px solid var(--line-soft); border-radius:12px; padding:11px 14px; font-size:13px; color:var(--fg-2); margin-bottom:18px; }
  .ws-meta b{ color:var(--teal); }
  .ws-actions{ display:grid; gap:10px; }
  .ws-cal{ display:inline-flex; align-items:center; justify-content:center; gap:8px; background:var(--white);
    color:var(--teal); font-weight:600; font-size:14px; padding:11px 16px; border-radius:999px; text-decoration:none; border:1px solid var(--line); }
  .ws-cal .ic{ width:16px; height:16px; color:#107a2f; }
  .ws-ics{ font-size:12px; color:var(--fg-3); text-decoration:underline; margin-top:2px; display:inline-block; }
  .ws-pid{ font-family:var(--font-mono); font-size:11px; color:var(--fg-3); margin-top:14px; }
</style>
</head>
<body>
