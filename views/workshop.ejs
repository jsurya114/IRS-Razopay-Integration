<!DOCTYPE html>
<html lang="en">
<meta http-equiv="content-type" content="text/html;charset=utf-8" />
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<script src="meta-pixel.js"></script>
<script src="clarity.js"></script>
<title>Score 79+ in PTE in 4 Hours — Live Masterclass · IRS Learning</title>
<meta name="description" content="A 4-hour live PTE masterclass that teaches exactly what the scoring algorithm rewards. Sat 11 July, 10AM–2PM IST. ₹589. By a Pearson-certified trainer.">
<link rel="preconnect" href="https://fonts.googleapis.com/">
<link rel="preconnect" href="https://fonts.gstatic.com/" crossorigin>
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Exo+2:ital,wght@0,400;0,500;0,600;0,700;0,800;1,400;1,600;1,800&amp;display=swap">
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700&amp;display=swap">
<link rel="stylesheet" href="workshop-tokens.css">
<style>
  :root{
    --font-mono:"JetBrains Mono", ui-monospace, "SF Mono", Menlo, monospace;
    /* crisper, less-washed-out text (fixes the dull/flat look) */
    --fg-2:#2b4248;   /* body — solid dark teal-slate */
    --fg-3:#5f777c;   /* muted */
    --ink:#15262b;
  }

  body{ background:var(--paper); color:var(--fg-2); }
  .wrap{ overflow-x:clip; }
  .inner{ max-width:1140px; margin:0 auto; padding:0 22px; }

  /* GrowthSchool-calm headings — override the extrabold/tight base */
  h1,h2,h3,h4{ font-family:var(--font-sans); color:var(--teal); font-weight:800;
    letter-spacing:-0.018em; line-height:1.08; text-wrap:balance; margin:0; }
  em.ac{ font-style:normal; color:#107a2f; }
  .dark em.ac, .hero-card em.ac{ color:#107a2f; }

  /* —— reveal —— */
  .rev{ opacity:1; }
  .js .rev{ opacity:0; transform:translateY(16px); }
  .js .rev.in{ opacity:1; transform:none; transition:opacity .7s var(--ease-out), transform .7s var(--ease-out); }
  .js .rev.d1{ transition-delay:.06s } .js .rev.d2{ transition-delay:.12s } .js .rev.d3{ transition-delay:.18s } .js .rev.d4{ transition-delay:.24s }
  /* mobile: fast thumb-scrolls outrun a .7s reveal — blank space reads as broken */
  @media (max-width:880px){
    .js .rev{ transform:translateY(8px); }
    .js .rev.in{ transition-duration:.4s, .4s; }
    .js .rev.d1{ transition-delay:.03s } .js .rev.d2{ transition-delay:.06s } .js .rev.d3{ transition-delay:.09s } .js .rev.d4{ transition-delay:.12s }
  }
  @media (prefers-reduced-motion:reduce){ .js .rev{ opacity:1!important; transform:none!important; } }

  .ic{ width:18px; height:18px; stroke:currentColor; fill:none; stroke-width:1.7; stroke-linecap:round; stroke-linejoin:round; flex:none; }

  /* —— the machine voice —— */
  .mono{ font-family:var(--font-mono); font-feature-settings:"tnum" 1; }
  .kick{ font-family:var(--font-mono); font-size:11.5px; font-weight:600; letter-spacing:.16em;
    text-transform:uppercase; color:#107a2f; display:inline-flex; align-items:center; gap:11px; }
  .kick::before{ content:""; width:24px; height:1px; background:#107a2f; opacity:.55; }
  .kick.c{ justify-content:center; }
  .dark .kick{ color:var(--gold-light); } .dark .kick::before{ background:var(--gold-light); }

  /* —— buttons (gold sheen) —— */
  .btn{ font-family:var(--font-sans); font-weight:700; font-size:15px; line-height:1;
    display:inline-flex; align-items:center; justify-content:center; gap:9px; padding:15px 26px;
    border-radius:var(--radius-pill); border:0; cursor:pointer; text-decoration:none;
    transition:transform .2s var(--ease-out), box-shadow .3s var(--ease-out); position:relative; overflow:hidden; }
  .btn:hover{ transform:translateY(-2px); }
  .btn-primary{ background:#115f2a; color:#fff; box-shadow:0 12px 30px -12px rgba(251,189,41,.55); }
  .btn-primary:hover{ box-shadow:0 18px 42px -12px rgba(251,189,41,.62); }
  .btn-primary::after{ content:""; position:absolute; top:0; left:-70%; width:45%; height:100%;
    background:linear-gradient(100deg,transparent,rgba(255,255,255,.55),transparent); transform:skewX(-18deg); pointer-events:none; }
  .btn-primary:hover::after{ animation:sheen .85s var(--ease-out); }
  @keyframes sheen{ from{left:-70%} to{left:150%} }
  .btn-ghost{ background:transparent; color:var(--teal); border:1px solid var(--line); }
  .btn-ghost:hover{ background:var(--white); }
  .btn .ic{ stroke-width:2.2; }
  .btn-lg{ padding:17px 32px; font-size:16px; }
  .btn-block{ width:100%; }

  /* —— sections —— */
  .sec{ padding:54px 0; }
  .sec-hd{ max-width:660px; }
  .sec-hd.c{ margin:0 auto; text-align:center; }
  .sec-hd h2{ font-size:clamp(28px,5.4vw,44px); line-height:1.06; margin-top:16px; }
  .sec-hd p{ margin-top:16px; font-size:16px; line-height:1.62; color:var(--fg-2); }
  .cta-row{ margin-top:34px; display:flex; flex-wrap:wrap; gap:14px 18px; align-items:center; }
  .cta-row.c{ justify-content:center; }
  .nospam{ display:inline-flex; align-items:center; gap:7px; font-size:13px; color:var(--fg-3); }
  .nospam .ic{ width:15px; height:15px; color:var(--success); }

  /* —— NAV (floating glass pill — matches /apply) —— */
  .nav{ position:sticky; top:0; z-index:40; padding:18px 22px 0; }
  .nav-pill{ max-width:1096px; margin:0 auto; display:flex; align-items:center; gap:16px;
    height:82px; padding:0 18px 0 24px; border-radius:22px;
    background:rgba(14,72,82,.06); border:1px solid rgba(14,72,82,.10);
    backdrop-filter:blur(10px); -webkit-backdrop-filter:blur(10px);
    transition:background .4s var(--ease-out), border-color .4s var(--ease-out), box-shadow .4s var(--ease-out), height .4s var(--ease-out); }
  .nav.scrolled .nav-pill{ height:70px; background:rgba(255,255,255,.85);
    backdrop-filter:blur(20px) saturate(140%); -webkit-backdrop-filter:blur(20px) saturate(140%);
    border-color:rgba(14,72,82,.08); box-shadow:0 4px 24px rgba(14,72,82,.08); }
  .nav-logo{ display:flex; align-items:center; flex:none; }
  .nav-logo img{ height:62px; width:auto; display:block; transition:height .4s var(--ease-out); }
  .nav.scrolled .nav-logo img{ height:52px; }
  .nav-right{ margin-left:auto; display:flex; align-items:center; gap:16px; }
  .nav-cd{ display:none; align-items:center; gap:7px; font-family:var(--font-mono); font-size:13px;
    color:var(--fg-2); opacity:0; transform:translateY(-4px); transition:opacity .3s, transform .3s; }
  .nav-cd.show{ opacity:1; transform:none; } .nav-cd b{ color:var(--teal); }
  .nav-cd .ic{ width:15px; height:15px; color:#107a2f; }
  .nav .btn{ padding:13px 24px; font-size:14.5px; }
  @media (min-width:720px){ .nav-cd{ display:inline-flex; } }
  @media (max-width:560px){
    .nav{ padding:12px 14px 0; }
    .nav-pill{ height:64px; padding:0 12px 0 16px; border-radius:18px; gap:10px; }
    .nav-logo img{ height:44px; }
    .nav.scrolled .nav-pill{ height:58px; }
    .nav.scrolled .nav-logo img{ height:40px; }
    .nav .btn{ padding:11px 18px; font-size:13.5px; }
  }

  /* —— HERO —— */
  .hero{ padding:22px 0 0; }
  .hero-card{ position:relative; overflow:hidden; border-radius:28px; background: #052a20;
    color:var(--paper); padding:clamp(26px,4.6vw,52px); }
  .grid-tx{ position:absolute; inset:0; pointer-events:none; opacity:.6;
    background-image:linear-gradient(rgba(255,255,255,.04) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.04) 1px,transparent 1px);
    background-size:52px 52px; mask-image:radial-gradient(120% 120% at 70% 0%, #000 35%, transparent 80%); }
  .glow{ position:absolute; width:560px; height:560px; border-radius:50%; pointer-events:none;
    background:radial-gradient(circle, rgba(251,189,41,.15), transparent 64%); top:-230px; right:-160px; }
  .hero-inner{ position:relative; display:grid; gap:32px; align-items:center; }
.eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: #f0c154;
}
  .live{ width:8px; height:8px; border-radius:50%; background:#ff6a5a; position:relative; flex:none; }
  .live::after{ content:""; position:absolute; inset:-4px; border-radius:50%; border:1.5px solid #ff6a5a; opacity:.5; animation:ping 2s var(--ease-out) infinite; }
  @keyframes ping{ 0%{transform:scale(.55);opacity:.6} 100%{transform:scale(2.4);opacity:0} }
  @media (prefers-reduced-motion:reduce){ .live::after{ animation:none } }

  .hero-card h1{ font-size:clamp(38px,6.6vw,62px); line-height:1.0; color:#fff; margin:18px 0 0; font-weight:800; letter-spacing:-0.022em; }
.hero-card h1 em {
    font-style: normal;
    color: #f0c154;
}
  .hero-card .h-sub{ margin-top:16px; font-size:clamp(16px,2.3vw,20px); font-weight:500; color:rgba(247,245,240,.85); letter-spacing:-0.005em; line-height:1.4; }
  .hero-card .h-sub b{ color:#fff; font-weight:700; }
  .hero-card .h-sub b{ color:#f0c154; font-weight:700; }
  .hero-card .lede{ margin-top:16px; font-size:16px; line-height:1.6; color:rgba(247,245,240,.78); max-width:48ch; font-weight:500; }
  .hero-card .lede b{ color:#fff; font-weight:600; }

  .h-meta{ display:flex; flex-wrap:wrap; gap:9px 18px; margin-top:24px; }
  .h-meta span{ display:inline-flex; align-items:center; gap:7px; font-family:var(--font-mono); font-size:12.5px; color:rgba(247,245,240,.72); }
  .h-meta .ic{ width:15px; height:15px; color:var(--gold-light); }

  .h-cta{ display:flex; align-items:center; gap:18px; flex-wrap:wrap; margin-top:30px; }
  .h-price{ font-family:var(--font-mono); font-size:13px; color:rgba(247,245,240,.62); }
  .h-price b{ font-size:18px; font-weight:700; color:#fff; }
  .h-price s{ color:rgba(247,245,240,.4); margin-right:7px; }
  .h-nospam{ display:inline-flex; align-items:center; gap:7px; font-size:12.5px; color:rgba(247,245,240,.55); margin-top:16px; }
  .h-nospam .ic{ width:14px; height:14px; color:var(--gold-light); }

  /* —— native Google reviews badge —— */
  .gbadge{ display:inline-flex; align-items:center; gap:10px; background:var(--white); border:1px solid var(--line); border-radius:13px; padding:9px 14px; text-decoration:none; box-shadow:var(--shadow-card); }
  .gbadge-g{ width:24px; height:24px; flex:none; }
  .gbadge-body{ display:flex; flex-direction:column; line-height:1.12; }
  .gbadge-top{ display:flex; align-items:center; gap:6px; }
  .gbadge-top b{ font-size:17px; color:var(--teal); font-weight:700; }
  .gstars{ color:#FBBC04; letter-spacing:1px; font-size:13px; }
  .gbadge-sub{ font-size:11.5px; color:var(--fg-3); }
  .gbadge.on-dark{ background:rgba(255,255,255,.07); border-color:rgba(255,255,255,.15); box-shadow:none; }
  .gbadge.on-dark .gbadge-top b{ color:#fff; }
  .gbadge.on-dark .gbadge-sub{ color:rgba(247,245,240,.6); }
  .nav-g{ padding:6px 11px; border-radius:11px; }
  .nav-g .gbadge-g{ width:19px; height:19px; }
  .nav-g .gbadge-top b{ font-size:14px; }
  .nav-g .gstars{ font-size:10px; }
  .nav .gbadge{ display:none; }
  @media (min-width:720px){ .nav .gbadge{ display:inline-flex; } }

  /* —— hero value bullets (the "what you get") —— */
  .h-gets{ list-style:none; margin:22px 0 0; padding:0; display:grid; gap:12px; }
  .h-gets li{ display:flex; gap:11px; font-size:15.5px; color:rgba(247,245,240,.86); line-height:1.4; }
  .h-gets li .ic{ width:19px; height:19px; color:#107a2f; margin-top:1px; flex:none; stroke-width:2.6; }
  .h-gets li b{ color:#f0c154; font-weight:700; }
  .hero-foot{ display:flex; align-items:center; gap:8px 20px; flex-wrap:wrap; margin-top:22px; }

  /* —— hero enroll card (lean: one clear path to the button) —— */
  .enroll{ background:var(--white); border-radius:22px; padding:24px; position:relative; overflow:hidden;
    box-shadow:0 44px 90px -38px rgba(0,0,0,.6), 0 4px 16px -6px rgba(0,0,0,.18); color:var(--fg-2); }
.enroll::before {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    top: 0;
    height: 10px;
    background: linear-gradient(90deg, #1e8536, #1e8536);
}
  .enroll-top{ display:flex; align-items:center; justify-content:space-between; gap:10px; margin-top:3px; }
  .enroll-live{ display:inline-flex; align-items:center; gap:7px; font-family:var(--font-mono); font-size:11px; font-weight:700; letter-spacing:.07em; text-transform:uppercase; color:#D23B30; }
  .enroll-meta{ font-family:var(--font-mono); font-size:10.5px; letter-spacing:.05em; text-transform:uppercase; color:var(--fg-3); }
  .enroll-head{ display:flex; flex-direction:column; align-items:flex-start; gap:13px; }
  @media (min-width:520px){ .enroll-head{ flex-direction:row; align-items:center; justify-content:space-between; gap:14px; } }
  .enroll-price{ display:flex; align-items:flex-end; gap:10px; }
  .ep-left{ display:flex; align-items:flex-end; gap:11px; }
  .ep-grev{ display:flex; align-items:center; gap:8px; text-decoration:none; flex:none; }
  .ep-grev .gbadge-g{ width:26px; height:26px; flex:none; }
  .epg-body{ display:flex; flex-direction:column; line-height:1.12; }
  .epg-top{ display:flex; align-items:center; gap:5px; }
  .epg-top b{ font-size:17px; color:var(--teal); font-weight:800; letter-spacing:-0.01em; }
  .epg-top .gstars{ font-size:11px; color:#FBBC04; letter-spacing:.5px; }
  .epg-sub{ font-size:10.5px; color:var(--fg-3); }
  .ep-now{ font-size:50px; font-weight:800; color:var(--teal); letter-spacing:-0.04em; line-height:.82; }
  .ep-meta{ display:flex; flex-direction:column; gap:5px; padding-bottom:3px; }
  .ep-meta s{ font-size:15px; color:var(--fg-3); }
  .ep-off{ font-size:10px; font-weight:800; color:#107a2f; background:var(--gold-soft); padding:3px 8px; border-radius:999px; letter-spacing:.05em; width:max-content; }
  .enroll .btn{ margin-top:16px; }
  .enroll-urg{ display:flex; align-items:center; justify-content:flex-start; gap:7px; margin-top:15px; padding-top:16px; border-top:1px solid var(--line); font-family:var(--font-mono); font-size:12px; color:var(--fg-2); }
  .enroll-urg .ic{ width:14px; height:14px; color:#107a2f; flex:none; }
  .enroll-urg b{ color:var(--teal); font-variant-numeric:tabular-nums; }
  .enroll-seats{ margin-top:16px; }
  .es-top{ display:flex; align-items:center; justify-content:space-between; margin-bottom:9px; }
  .es-lab{ font-family:var(--font-mono); font-size:11px; letter-spacing:.08em; text-transform:uppercase; color:var(--fg-3); }
  .es-warn{ display:inline-flex; align-items:center; gap:5px; font-family:var(--font-mono); font-size:10px; font-weight:700; letter-spacing:.06em; text-transform:uppercase; color:#107a2f; background:var(--gold-soft); padding:3px 9px; border-radius:999px; }
  .es-warn::before{ content:""; width:5px; height:5px; border-radius:50%; background:#107a2f; }
  .enroll-cd{ margin-top:18px; }
  .ecd-lab{ display:block; font-family:var(--font-mono); font-size:10.5px; letter-spacing:.14em; text-transform:uppercase; color:var(--fg-3); margin-bottom:9px; }
  .ecd-grid{ display:flex; gap:7px; }
  .ecd-u{ flex:1; text-align:center; background:var(--teal-950); border-radius:10px; padding:11px 2px 9px; }
  .ecd-u b{ display:block; font-family:var(--font-mono); font-weight:700; font-size:23px; color:#fff; line-height:1; font-variant-numeric:tabular-nums; }
  .ecd-u small{ font-family:var(--font-mono); font-size:8px; letter-spacing:.1em; text-transform:uppercase; color:var(--gold-light); margin-top:6px; display:block; }
  .es-t{ font-family:var(--font-mono); font-size:11px; color:var(--fg-3); text-align:left; margin-top:8px; }
  .es-t b{ color:var(--teal); }
  .enroll-grev{ display:flex; flex-direction:column; align-items:flex-start; gap:5px; flex:none; text-decoration:none;
    background:var(--gold-soft); border:1px solid rgba(224,165,15,.22); border-radius:13px; padding:10px 13px;
    transition:border-color .18s var(--ease-out), box-shadow .18s var(--ease-out); }
  .enroll-grev:hover{ border-color:rgba(224,165,15,.45); box-shadow:0 6px 16px -10px rgba(224,165,15,.4); }
  .egr-top{ display:flex; align-items:center; gap:7px; }
  .enroll-grev .gbadge-g{ width:20px; height:20px; flex:none; }
  .enroll-grev b{ font-size:17px; color:var(--teal); font-weight:800; letter-spacing:-0.01em; line-height:1; }
  .enroll-grev .gstars{ font-size:12px; color:#FBBC04; letter-spacing:1px; }
  .enroll-grev .egr-sub{ font-size:11.5px; color:var(--fg-3); font-weight:500; }
  .enroll-secure{ display:flex; align-items:center; justify-content:center; gap:6px; margin-top:15px; padding-top:14px; border-top:1px solid var(--line); font-size:11px; color:var(--fg-3); }
  .enroll-secure .ic{ width:13px; height:13px; color:var(--success); flex:none; }
  .enroll-when{ margin-top:16px; padding:15px 16px; border:1px solid var(--line); border-radius:14px; background:var(--paper-card); display:grid; gap:12px; }
  .ew-row{ display:flex; align-items:center; gap:12px; font-size:14px; color:var(--fg-2); line-height:1.3; }
  .ew-row .ic{ width:17px; height:17px; color:#107a2f; flex:none; }
  .ew-row b{ color:var(--teal); font-weight:700; }
  .proof2{ display:flex; align-items:center; gap:14px 22px; flex-wrap:wrap; }
  .proof2-txt{ font-size:14.5px; color:var(--fg-2); line-height:1.5; max-width:52ch; }
  .proof2-txt b{ color:var(--teal); }

  /* —— SCORECARD (hero lead visual + results) —— */
  .sc-wrap{ position:relative; }
  .scorecard{ background:var(--white); color:var(--fg-2); border-radius:16px; padding:22px;
    box-shadow:0 30px 70px -28px rgba(0,0,0,.6); border:1px solid rgba(255,255,255,.5); margin:0;
    transform:rotate(-1.4deg); transition:transform .4s var(--ease-out); }
  .sc-wrap:hover .scorecard{ transform:rotate(0); }
  .sc-top{ display:flex; align-items:center; justify-content:space-between; gap:12px; padding-bottom:14px; border-bottom:1px solid var(--line); }
  .sc-brand{ font-family:var(--font-mono); font-size:10.5px; letter-spacing:.1em; color:var(--fg-3); font-weight:600; }
  .sc-ver{ display:inline-flex; align-items:center; gap:5px; font-family:var(--font-mono); font-size:10.5px; color:var(--success); font-weight:600; }
  .sc-ver .ic{ width:13px; height:13px; }
  .sc-name{ display:flex; align-items:center; gap:10px; margin:13px 0; }
  .sc-name .redact{ height:11px; flex:1; max-width:130px; border-radius:3px;
    background:repeating-linear-gradient(90deg,var(--cream-dark),var(--cream-dark) 8px,var(--paper-warm) 8px,var(--paper-warm) 14px); }
  .sc-name small{ font-family:var(--font-mono); font-size:9.5px; color:var(--fg-3); }
  .sc-overall{ display:flex; align-items:flex-end; gap:12px; margin:6px 0 18px; }
  .sc-overall .lab{ font-family:var(--font-mono); font-size:10px; letter-spacing:.12em; text-transform:uppercase; color:var(--fg-3); display:block; margin-bottom:2px; }
  .sc-overall .big{ font-family:var(--font-mono); font-weight:700; font-size:58px; line-height:.82; color:var(--teal); letter-spacing:-0.03em; }
  .sc-overall .scale{ font-family:var(--font-mono); font-size:14px; color:var(--fg-3); padding-bottom:6px; }
  .sc-overall .seal{ margin-left:auto; width:46px; height:46px; border-radius:50%; border:1.5px dashed #107a2f;
    display:grid; place-items:center; font-family:var(--font-mono); font-size:8px; font-weight:600; color:#107a2f; text-align:center; line-height:1.1; }
  .sc-skill{ display:grid; grid-template-columns:78px 1fr 30px; align-items:center; gap:10px; margin:9px 0; }
  .sc-skill .nm{ font-family:var(--font-mono); font-size:11px; letter-spacing:.04em; text-transform:uppercase; color:var(--fg-2); }
  .sc-skill .track{ height:7px; border-radius:999px; background:var(--cream-dark); overflow:hidden; }
  .sc-skill .fill{ display:block; height:100%; border-radius:999px; background:linear-gradient(90deg,var(--teal-light),var(--teal)); width:0; transition:width 1.1s var(--ease-out) .2s; }
  .sc-skill .vl{ font-family:var(--font-mono); font-size:13px; font-weight:600; color:var(--teal); text-align:right; }
  .scorecard.in .fill{ width:var(--w); }
  .sc-foot{ margin-top:14px; padding-top:12px; border-top:1px solid var(--line); font-family:var(--font-mono); font-size:9.5px; color:var(--fg-3); line-height:1.5; }
  .sc-badge{ position:absolute; top:-14px; right:-10px; z-index:2; display:inline-flex; align-items:center; gap:7px;
    background:#107a2f; color:var(--teal-dark); border-radius:999px; padding:8px 14px; font-weight:700; font-size:13px;
    box-shadow:0 12px 26px -10px rgba(251,189,41,.6); }
  .sc-badge .stars{ font-size:11px; }
  .sc-badge small{ font-weight:500; font-size:11px; opacity:.85; }

  /* —— PROOF BAND —— */
  .proof{ display:flex; flex-wrap:wrap; align-items:center; gap:14px 26px; padding:26px 0 2px; }
  .proof .g{ display:inline-flex; align-items:center; gap:10px; }
  .proof .g .rate{ font-family:var(--font-mono); font-weight:700; font-size:22px; color:var(--teal); }
  .proof .g .stars{ color:#107a2f; letter-spacing:1px; font-size:15px; }
  .proof .g .sub{ font-size:13.5px; color:var(--fg-2); } .proof .g .sub b{ color:var(--teal); }
  .proof .g .sub a{ color:#107a2f; text-decoration:underline; text-underline-offset:2px; }
  .proof .vr{ width:1px; height:34px; background:var(--line); }
  .proof .geo{ font-size:13.5px; color:var(--fg-2); display:inline-flex; align-items:center; gap:8px; }
  .proof .geo .ic{ width:16px; height:16px; color:#107a2f; }

  /* —— POSITIONING (contained dark card) —— */
  .posn{ background:var(--teal-950); color:var(--paper); border-radius:22px; padding:clamp(28px,4vw,46px);
    position:relative; overflow:hidden; display:grid; gap:18px; }
  .posn::before{ content:""; position:absolute; inset:0; pointer-events:none;
    background:radial-gradient(680px 360px at 88% -20%, rgba(251,189,41,.1), transparent 60%); }
  .posn .q{ position:relative; font-size:clamp(22px,3.4vw,32px); line-height:1.28; font-weight:700; color:#fff; letter-spacing:-0.01em; max-width:24ch; }
  .posn .q em{ font-style:normal; color:#107a2f; }
  .posn .s{ position:relative; font-size:15.5px; line-height:1.6; color:rgba(247,245,240,.74); max-width:54ch; }

  /* —— PROBLEM —— */
  .prob-grid{ margin-top:6px; border-top:1px solid var(--line); }
  .prob{ display:grid; grid-template-columns:48px 1fr; gap:16px; padding:26px 0; border-bottom:1px solid var(--line); align-items:start; }
  .prob .no{ font-family:var(--font-mono); font-size:13px; color:#107a2f; padding-top:3px; }
  .prob h4{ font-size:19px; margin-bottom:6px; }
  .prob p{ font-size:15px; line-height:1.58; color:var(--fg-2); max-width:54ch; }
  .pivot{ text-align:center; max-width:26ch; margin:42px auto 0; font-size:clamp(22px,3.6vw,32px);
    font-weight:700; color:var(--teal); line-height:1.26; letter-spacing:-0.01em; }
  .pivot em{ font-style:normal; color:#107a2f; }

  /* —— DARK section (algorithm / final) —— */
  .dark{ background:var(--teal-950); color:var(--paper); position:relative; overflow:hidden; }
  .dark::before{ content:""; position:absolute; inset:0; pointer-events:none;
    background:radial-gradient(900px 480px at 82% -10%, rgba(251,189,41,.09), transparent 60%); }
  .dark .inner{ position:relative; }
  .dark .sec-hd h2{ color:#fff; } .dark .sec-hd p{ color:rgba(247,245,240,.78); }
  .alg-grid{ display:grid; gap:14px; margin-top:36px; }
  .alg{ background:rgba(255,255,255,.04); border:1px solid rgba(255,255,255,.1); border-radius:16px; padding:24px; }
  .alg .n{ font-family:var(--font-mono); font-size:12px; color:var(--gold-light); }
  .alg h4{ color:#fff; font-size:18px; margin:12px 0 8px; }
  .alg p{ color:rgba(247,245,240,.72); font-size:14.5px; line-height:1.55; }

  /* —— SECTION 3 · THE ALGORITHM HOOK — editorial "watch the machine read" —— */
  .hook{ position:relative; overflow:hidden; background:var(--teal-950); color:var(--paper);
    border-radius:26px; padding:clamp(30px,4.2vw,56px); }
  .hook::before{ content:""; position:absolute; right:-12%; top:-45%; width:72%; height:135%;
    background:radial-gradient(ellipse at center, rgba(251,189,41,.12), transparent 60%); pointer-events:none; }
  .hook>*{ position:relative; }
  .hook-grid{ display:grid; grid-template-columns:0.82fr 1.18fr; gap:clamp(28px,4vw,56px); align-items:center; }
  .hook .kick{ color:var(--gold-light); }
  .hook .kick::before{ background:var(--gold-light); }
  .hook-q{ font-family:var(--font-sans); font-weight:800; font-size:clamp(27px,3.2vw,39px); line-height:1.06;
    letter-spacing:-0.025em; color:#fff; margin:18px 0 0; }
  .hook-q em{ font-style:normal; color:#107a2f; }
  .hook-lead{ font-size:15.5px; line-height:1.64; color:rgba(247,245,240,.72); margin:18px 0 0; max-width:44ch; }
  .hook-lead em{ font-style:normal; color:#107a2f; font-weight:600; }
  .hook-lede .cta-row{ margin-top:30px; }

  /* the reader artifact — the machine's-eye view of an answer */
  .reader{ background:rgba(255,255,255,.05); border:1px solid rgba(255,255,255,.12); border-radius:18px;
    box-shadow:0 44px 90px -42px rgba(0,0,0,.85); overflow:hidden; }
  .reader-bar{ display:flex; align-items:center; gap:9px; padding:14px 20px; border-bottom:1px solid rgba(255,255,255,.08);
    font-family:var(--font-mono); font-size:10.5px; letter-spacing:.16em; text-transform:uppercase; color:rgba(247,245,240,.55); }
  .reader-bar .dot{ width:8px; height:8px; border-radius:50%; background:#107a2f; box-shadow:0 0 11px #107a2f; flex:none; }
  .reader-status{ margin-left:auto; letter-spacing:.06em; color:rgba(247,245,240,.4); text-transform:none; }
  .reader-text{ padding:26px 24px 8px; font-size:17px; line-height:2; color:rgba(247,245,240,.92); font-weight:400; }
  .reader-text mark{ background:rgba(251,189,41,.16); color:#fff; border-bottom:1.5px solid #107a2f;
    border-radius:3px 3px 0 0; padding:1px 3px; box-decoration-break:clone; -webkit-box-decoration-break:clone;
    transition:background .35s var(--ease-out), color .35s var(--ease-out), border-color .35s var(--ease-out); }
  .reader-text mark.pre{ background:transparent; color:rgba(247,245,240,.5); border-bottom-color:transparent; }
  .reader-tags{ display:flex; flex-wrap:wrap; gap:7px; padding:16px 24px 22px; }
  .rt{ font-family:var(--font-mono); font-size:10.5px; color:#107a2f; background:rgba(251,189,41,.1);
    border:1px solid rgba(251,189,41,.22); border-radius:999px; padding:3px 11px;
    transition:opacity .4s var(--ease-out), transform .4s var(--ease-out); }
  .rt.pre{ opacity:0; transform:translateY(7px); }
  .rv-num{ font-variant-numeric:tabular-nums; }
  .reader-verdict{ display:flex; align-items:flex-end; justify-content:space-between; gap:16px;
    padding:16px 24px; border-top:1px solid rgba(255,255,255,.08); background:rgba(0,0,0,.2); }
  .rv-ignored{ font-family:var(--font-mono); font-size:11px; line-height:1.55; color:rgba(247,245,240,.42); max-width:32ch; }
  .rv-ignored b{ color:rgba(247,245,240,.62); font-weight:600; }
  .rv-score{ font-family:var(--font-mono); font-size:10px; color:rgba(247,245,240,.5); white-space:nowrap; text-align:right; text-transform:uppercase; letter-spacing:.12em; }
  .rv-score b{ display:block; font-size:34px; color:#107a2f; font-weight:700; letter-spacing:-0.02em; line-height:1; margin-top:4px; }

  /* motion graphic (the "machine scoring your answer" explainer) is JS-driven — see #reader-anim script.
     Default state = finished (highlighted, tags shown, Band 79) so it's safe + correct without JS / with reduced-motion. */

  @media (max-width:820px){
    .hook-grid{ grid-template-columns:1fr; gap:30px; }
    .hook-lead{ max-width:none; }
  }
  @media (max-width:520px){ .reader-status{ display:none; } .reader-text{ font-size:16px; line-height:1.9; } }

  /* —— HOW IT WORKS —— */
  .steps{ display:grid; gap:14px; margin-top:36px; counter-reset:s; }
  .step{ background:var(--white); border:1px solid var(--border-soft); border-radius:18px; padding:26px; box-shadow:var(--shadow-card); position:relative; }
  .step .sn{ font-family:var(--font-mono); font-weight:700; font-size:13px; color:#107a2f;
    width:34px; height:34px; border-radius:50%; background:var(--gold-soft); display:grid; place-items:center; margin-bottom:16px; }
  .step h4{ font-size:18px; margin-bottom:8px; }
  .step p{ font-size:14.5px; line-height:1.55; color:var(--fg-2); }
  .step .ar{ display:none; }

  /* —— CURRICULUM · "THE AGENDA" — light premium syllabus (Maven-grade restraint) —— */
  .ag-meta{ display:flex; flex-wrap:wrap; align-items:center; margin-top:20px; font-family:var(--font-mono);
    font-size:11.5px; letter-spacing:.08em; text-transform:uppercase; color:var(--fg-3); }
  .ag-meta span + span::before{ content:"·"; margin:0 13px; color:var(--line); }
  .ag-meta b{ color:var(--teal); font-weight:700; }

  .agenda{ margin-top:26px; background:var(--white); border:1px solid var(--line); border-radius:20px; overflow:hidden; box-shadow:var(--shadow-card); }
  .ag-row{ display:grid; grid-template-columns:108px 1fr; gap:0 28px; padding:28px 30px;
    border-top:1px solid var(--line-soft); transition:background .2s var(--ease-out); }
  .agenda .ag-row:first-child{ border-top:0; }
  .ag-row:hover{ background:var(--paper-card); }
  .ag-rail{ display:flex; flex-direction:column; align-items:flex-start; gap:12px; }
  .ag-num{ font-family:var(--font-mono); font-size:23px; font-weight:700; color:var(--teal); opacity:.3; letter-spacing:-0.02em; line-height:1; }
  .ag-dur{ font-family:var(--font-mono); font-size:10.5px; font-weight:700; letter-spacing:.06em; text-transform:uppercase;
    color:#107a2f; background:var(--gold-soft); border:1px solid var(--border-gold); border-radius:999px; padding:5px 11px; white-space:nowrap; }
  .ag-skill{ font-family:var(--font-mono); font-size:10.5px; font-weight:600; letter-spacing:.13em; text-transform:uppercase; color:var(--fg-3); }
  .ag-title{ font-family:var(--font-sans); font-weight:700; font-size:clamp(18px,2vw,21px); color:var(--teal);
    letter-spacing:-0.015em; line-height:1.26; margin:8px 0 0; max-width:36ch; }
  .ag-outs{ list-style:none; margin:15px 0 0; padding:0; display:grid; gap:9px; }
  .ag-outs li{ position:relative; padding-left:26px; font-size:14.5px; line-height:1.5; color:var(--fg-2); max-width:62ch; }
  .ag-outs li .ic{ position:absolute; left:0; top:2px; width:16px; height:16px; color:var(--teal-light); stroke-width:2.6; }
  .ag-outs li b{ color:var(--teal); font-weight:600; }

  .ag-foot{ display:flex; align-items:center; gap:11px; margin-top:22px; font-size:15.5px; font-weight:500; color:var(--fg-2); line-height:1.45; }
  .ag-foot .ic{ width:20px; height:20px; color:#107a2f; flex:none; stroke-width:2.4; }
  .ag-foot b{ color:var(--teal); font-weight:700; }
  .ag-foot em{ font-style:normal; color:#107a2f; font-weight:700; }

  @media (max-width:680px){
    .ag-row{ grid-template-columns:1fr; gap:15px; padding:24px 20px; }
    .ag-rail{ flex-direction:row; align-items:center; gap:14px; }
    .ag-num{ font-size:19px; }
    .ag-title{ margin-top:0; }
  }

  /* —— VALUE · "IT PAYS FOR ITSELF" — break-even math + honest comparison —— */
  .vmath{ display:flex; flex-wrap:wrap; align-items:stretch; gap:12px; margin-top:30px; }
  .vm-cell{ flex:1 1 168px; background:var(--white); border:1px solid var(--line); border-radius:16px; padding:18px 20px; box-shadow:var(--shadow-card); }
  .vm-cell.net{ background:var(--gold-soft); border-color:var(--border-gold); box-shadow:none; }
  .vm-lab{ display:block; font-family:var(--font-mono); font-size:10px; letter-spacing:.1em; text-transform:uppercase; color:var(--fg-3); margin-bottom:10px; }
  .vm-num{ font-family:var(--font-mono); font-weight:700; font-size:clamp(28px,3.4vw,33px); letter-spacing:-0.02em; color:var(--teal); line-height:1; }
  .vm-cell.net .vm-num{ color:#107a2f; }
  .vm-op{ display:flex; align-items:center; font-family:var(--font-mono); font-size:20px; color:var(--fg-3); }
  .vmath-note{ font-size:14px; color:var(--fg-2); margin-top:15px; max-width:62ch; line-height:1.55; }
  .vmath-note b{ color:var(--teal); font-weight:600; }

  .vlabel{ font-family:var(--font-sans); font-weight:600; font-size:15.5px; color:var(--teal); margin-top:34px; }
  .vcompare{ margin-top:15px; border:1px solid var(--line); border-radius:18px; overflow:hidden; background:var(--white); box-shadow:var(--shadow-card); }
  .vc-row{ display:grid; grid-template-columns:210px 120px 1fr; gap:0 22px; padding:18px 24px; align-items:center; border-top:1px solid var(--line-soft); }
  .vcompare .vc-row:first-child{ border-top:0; }
  .vc-row.us{ background:var(--gold-soft); }
  .vc-name{ font-family:var(--font-sans); font-weight:700; font-size:15.5px; color:var(--teal); letter-spacing:-0.01em; }
  .vc-cost{ font-family:var(--font-mono); font-weight:700; font-size:17px; color:var(--fg-2); white-space:nowrap; }
  .vc-row.us .vc-cost{ color:#107a2f; }
  .vc-detail{ font-size:13.5px; color:var(--fg-2); line-height:1.45; }
  .vc-detail b{ color:var(--teal); font-weight:600; }

  .vguar{ display:flex; flex-wrap:wrap; gap:9px 20px; margin-top:24px; }
  .vguar span{ display:inline-flex; align-items:center; gap:8px; font-size:13.5px; color:var(--fg-3); }
  .vguar .ic{ width:16px; height:16px; color:var(--success); flex:none; }

  @media (max-width:680px){
    .vm-op{ width:100%; justify-content:center; color:#107a2f; font-size:19px; }
    .vm-cell{ flex-basis:100%; }
    .vc-row{ grid-template-columns:1fr auto; gap:4px 14px; padding:16px 18px; }
    .vc-detail{ grid-column:1 / -1; margin-top:5px; }
  }

  /* —— WHO IT'S FOR · "is this you?" — numbered self-select personas —— */
  .fit-lede{ font-size:16px; line-height:1.6; color:var(--fg-2); max-width:56ch; margin-top:16px; }
  .fit-lede b{ color:var(--teal); font-weight:600; }
  .fit{ display:grid; gap:14px; margin-top:32px; }
  .fit-card{ position:relative; background:var(--white); border:1px solid var(--line); border-radius:18px; padding:26px 28px;
    display:grid; grid-template-columns:auto 1fr; gap:0 20px; align-items:start; transition:border-color .2s var(--ease-out), background .2s var(--ease-out); }
  .fit-card:hover{ border-color:var(--teal-100); }
  .fit-num{ font-family:var(--font-mono); font-size:27px; font-weight:700; color:var(--teal-light); opacity:.55; letter-spacing:-0.02em; line-height:1; }
  .fit-h{ font-family:var(--font-sans); font-weight:700; font-size:17.5px; color:var(--teal); letter-spacing:-0.01em; margin:1px 0 6px; line-height:1.25; }
  .fit-p{ font-size:14.5px; line-height:1.55; color:var(--fg-2); margin:0; max-width:50ch; }
  .fit-card.hot{ background:var(--gold-soft); border-color:var(--border-gold); }
  .fit-card.hot .fit-num{ color:#107a2f; opacity:.85; }
  .fit-tag{ position:absolute; top:0; right:22px; transform:translateY(-50%); font-family:var(--font-mono);
    font-size:9px; font-weight:700; letter-spacing:.1em; text-transform:uppercase; color:#107a2f;
    background:var(--white); border:1px solid var(--border-gold); border-radius:999px; padding:4px 10px; }

  @media (min-width:720px){
    .fit{ grid-template-columns:repeat(2,1fr); }
  }

  /* —— MENTOR · dark "meet your trainer" spotlight —— */
  .trainer{ position:relative; overflow:hidden; background:var(--teal-950); color:var(--paper);
    border-radius:26px; padding:clamp(26px,4vw,50px); box-shadow:inset 0 1px 0 0 rgba(255,255,255,.05); }
  .trainer::before{ content:""; position:absolute; right:-12%; top:-45%; width:62%; height:135%; pointer-events:none;
    background:radial-gradient(ellipse at center, rgba(251,189,41,.12), transparent 60%); }
  .tr-grid{ position:relative; display:grid; gap:clamp(24px,4vw,44px); align-items:stretch; }

  .tr-photo{ position:relative; aspect-ratio:4/5; border-radius:18px; overflow:hidden; border:1px solid rgba(255,255,255,.12);
    background:linear-gradient(160deg,#0d3a43,#061e23); display:grid; place-items:center; }
  .tr-photo .silh{ width:48%; height:48%; color:rgba(255,255,255,.09); }
  .tr-photo img{ position:absolute; inset:0; width:100%; height:100%; object-fit:cover; object-position:50% 22%; }
  .tr-photo .ph-lab{ position:absolute; bottom:13px; left:50%; transform:translateX(-50%); white-space:nowrap;
    font-family:var(--font-mono); font-size:9.5px; letter-spacing:.1em; text-transform:uppercase; color:rgba(247,245,240,.42);
    background:rgba(0,0,0,.28); border:1px solid rgba(255,255,255,.1); padding:5px 11px; border-radius:999px; }
  /* google reviews card — aggregate rating + a sample review */
  .tr-rev{ margin-top:22px; padding:17px 20px; background:rgba(255,255,255,.04); border:1px solid rgba(255,255,255,.1); border-radius:14px; }
  .tr-rev-top{ display:flex; align-items:center; gap:9px; padding-bottom:13px; margin-bottom:13px; border-bottom:1px solid rgba(255,255,255,.08); }
  .tr-rev-top .gbadge-g{ width:20px; height:20px; flex:none; }
  .tr-rev-top b{ font-size:16px; color:#fff; font-weight:800; }
  .tr-rev-top .gstars{ font-size:11px; color:#FBBC04; letter-spacing:.6px; }
  .tr-rev-top small{ margin-left:auto; font-family:var(--font-mono); font-size:11px; color:rgba(247,245,240,.5); }
  .tr-revfeed{ position:relative; height:116px; overflow:hidden; margin-top:3px;
    -webkit-mask-image:linear-gradient(180deg,transparent,#000 12%,#000 88%,transparent);
    mask-image:linear-gradient(180deg,transparent,#000 12%,#000 88%,transparent); }
  .tr-revtrack{ animation:revroll 16s var(--ease-out) infinite; }
  .tr-revfeed:hover .tr-revtrack{ animation-play-state:paused; }
  .trv{ height:116px; box-sizing:border-box; margin:0; padding:4px 0; display:flex; flex-direction:column; justify-content:center;
    font-size:14.5px; line-height:1.6; color:rgba(247,245,240,.9); }
  .trv cite{ display:block; margin-top:10px; font-style:normal; font-family:var(--font-mono); font-size:11px; color:rgba(247,245,240,.5); }
  @keyframes revroll{
    0%,30%{ transform:translateY(0); }
    34%,63%{ transform:translateY(-25%); }
    67%,96%{ transform:translateY(-50%); }
    100%{ transform:translateY(-75%); }
  }
  @media (prefers-reduced-motion:reduce){
    .tr-revfeed{ height:auto; -webkit-mask-image:none; mask-image:none; }
    .tr-revtrack{ animation:none; }
    .trv{ height:auto; padding:11px 0; border-top:1px solid rgba(255,255,255,.08); }
    .trv:first-child{ padding-top:0; border-top:0; }
  }
  @media (max-width:680px){ .tr-revfeed{ height:142px; } .trv{ height:142px; } }

  .tr-kick{ font-family:var(--font-mono); font-size:11.5px; font-weight:600; letter-spacing:.16em; text-transform:uppercase;
    color:var(--gold-light); display:inline-flex; align-items:center; gap:10px; }
  .tr-kick::before{ content:""; width:22px; height:1px; background:var(--gold-light); opacity:.55; }
  .tr-name{ font-family:var(--font-sans); font-weight:800; font-size:clamp(26px,3.6vw,38px); color:#fff; letter-spacing:-0.02em; line-height:1.04; margin:13px 0 0; }
  .tr-role{ font-family:var(--font-mono); font-size:12px; letter-spacing:.03em; color:var(--gold-light); margin-top:10px; }
  .tr-bio{ font-size:15px; line-height:1.65; color:rgba(247,245,240,.78); margin:18px 0 0; max-width:54ch; }
  .tr-bio b{ color:#fff; font-weight:600; }
  .tr-creds{ display:flex; flex-wrap:wrap; gap:9px; margin-top:20px; }
  .tr-creds span{ display:inline-flex; align-items:center; gap:7px; font-size:12.5px; color:rgba(247,245,240,.82);
    background:rgba(255,255,255,.06); border:1px solid rgba(255,255,255,.12); border-radius:999px; padding:7px 13px; }
  .tr-creds .ic{ width:13px; height:13px; color:var(--gold-light); flex:none; stroke-width:2.6; }

  @media (min-width:820px){
    .tr-grid{ grid-template-columns:0.82fr 1.18fr; }
  }

  /* —— RESULTS —— */
  .res-grid{ display:grid; gap:14px; margin-top:34px; }
  .res{ background:var(--white); border:1px solid var(--border-soft); border-radius:16px; padding:24px; box-shadow:var(--shadow-card); }
  .jump{ display:flex; align-items:center; gap:12px; margin-bottom:14px; }
  .jump .from{ font-family:var(--font-mono); font-size:22px; color:var(--fg-3); font-weight:500; }
  .jump .arr{ color:#107a2f; }
  .jump .to{ font-family:var(--font-mono); font-size:38px; color:var(--teal); font-weight:700; letter-spacing:-0.02em; line-height:1; }
  .jump .stars{ margin-left:auto; color:#107a2f; letter-spacing:.5px; font-size:13px; }
  .res blockquote{ margin:0; font-size:15px; line-height:1.55; color:var(--ink); }
  .res .who{ font-family:var(--font-mono); font-size:12px; color:var(--fg-3); margin-top:12px; }
  .res .who b{ color:var(--teal); font-weight:600; }
  .res-disc{ font-family:var(--font-mono); font-size:11px; color:var(--fg-3); margin:30px auto 0; line-height:1.6; max-width:60ch; text-align:center; }
  /* real scorecard result cards */
  .res{ display:flex; flex-direction:column; margin:0; }
  .rc-frame{ background:var(--white); border:1px solid var(--line); border-radius:10px; padding:12px 10px; overflow:hidden; }
  .rc-img{ width:100%; height:auto; display:block; }
  .rc-foot{ display:flex; align-items:center; justify-content:space-between; margin-top:16px; }
  .rc-num{ font-family:var(--font-mono); font-weight:700; font-size:30px; color:var(--teal); letter-spacing:-0.02em; line-height:1; }
  .rc-num small{ font-size:11px; color:var(--fg-3); font-weight:500; margin-left:5px; letter-spacing:0; }
  .res .stars{ color:#107a2f; letter-spacing:.5px; font-size:13px; }
  .rc-who{ font-family:var(--font-mono); font-size:12px; color:var(--fg-3); margin-top:10px; }
  .rc-who b{ color:var(--teal); font-weight:600; }
  /* destinations strip */
  .dests{ margin-top:42px; text-align:center; }
  .dests-lab{ font-family:var(--font-sans); font-size:clamp(16px,2.1vw,18.5px); font-weight:700; letter-spacing:-0.01em; color:var(--teal); display:block; margin-bottom:22px; line-height:1.35; }
  .dests-lab b{ color:#107a2f; font-weight:700; }
  /* auto-scrolling logo marquee (wordmark tiles now → swap real logo <img> later) */
  .logos{ position:relative; margin-top:22px; overflow:hidden;
    -webkit-mask-image:linear-gradient(90deg,transparent,#000 7%,#000 93%,transparent);
    mask-image:linear-gradient(90deg,transparent,#000 7%,#000 93%,transparent); }
  .logos-track{ display:flex; gap:14px; width:max-content; animation:logos-scroll 38s linear infinite; }
  .logos:hover .logos-track{ animation-play-state:paused; }
  .logos-set{ display:flex; gap:14px; flex:none; }
  .logo{ flex:none; display:grid; place-items:center; height:62px; padding:0 28px;
    background:var(--white); border:1px solid var(--line); border-radius:14px; box-shadow:var(--shadow-card);
    font-family:var(--font-sans); font-weight:700; font-size:15px; color:var(--teal); letter-spacing:-0.01em; white-space:nowrap;
    transition:box-shadow .25s var(--ease-out), transform .25s var(--ease-out); }
  .logo:hover{ box-shadow:var(--shadow-lift); transform:translateY(-2px); }
  @keyframes logos-scroll{ to{ transform:translateX(-50%); } }
  @media (prefers-reduced-motion: reduce){
    .logos{ -webkit-mask-image:none; mask-image:none; }
    .logos-track{ animation:none; width:auto; flex-wrap:wrap; justify-content:center; }
    .logos-set[aria-hidden="true"]{ display:none; }
  }
  /* —— PROOF STRIP — recent results (Overall score + real Pearson circle row) —— */
  .proofhd{ display:flex; align-items:flex-end; justify-content:space-between; gap:22px 44px; flex-wrap:wrap; }
  .proofhd-l{ flex:1 1 360px; min-width:min(100%,360px); }
  .proofhd h2{ font-size:clamp(1.55rem,3.1vw,2.1rem); margin:13px 0 11px; }
  .proofhd .s{ font-size:14.5px; color:var(--fg-2); line-height:1.55; max-width:48ch; }
  .proofhd .s b{ color:var(--teal); font-weight:700; }
  .pstats{ display:flex; align-items:stretch; gap:11px; flex:none; }
  .pstat{ display:flex; flex-direction:column; justify-content:center; gap:4px; background:var(--white); border:1px solid var(--line); border-radius:14px; padding:13px 17px; box-shadow:var(--shadow-card); min-width:128px; }
  .pstat .n{ font-family:var(--font-mono); font-weight:700; font-size:25px; color:var(--teal); letter-spacing:-0.02em; line-height:1; }
  .pstat .l{ font-size:11.5px; color:var(--fg-3); font-weight:500; line-height:1.2; }
  .pstat.g{ background:var(--gold-soft); border-color:rgba(224,165,15,.22); text-decoration:none; transition:border-color .18s var(--ease-out), box-shadow .18s var(--ease-out); }
  .pstat.g:hover{ border-color:rgba(224,165,15,.45); box-shadow:0 6px 16px -10px rgba(224,165,15,.4); }
  .pstat.g .gtop{ display:flex; align-items:center; gap:7px; }
  .pstat.g .gbadge-g{ width:19px; height:19px; flex:none; }
  .pstat.g .gtop b{ font-family:var(--font-mono); font-size:21px; color:var(--teal); font-weight:700; line-height:1; letter-spacing:-0.02em; }
  .pstat.g .gstars{ font-size:11px; color:#FBBC04; letter-spacing:1px; }

  .scwall{ display:grid; grid-template-columns:repeat(4,1fr); gap:14px; margin-top:30px; }
  .scw{ margin:0; background:var(--white); border:1px solid var(--line); border-radius:16px; box-shadow:var(--shadow-card); overflow:hidden; cursor:zoom-in; display:flex; flex-direction:column;
    transition:transform .2s var(--ease-out), box-shadow .3s var(--ease-out); }
  .scw:hover{ transform:translateY(-4px); box-shadow:var(--shadow-lift); }
  .scw:focus-visible{ outline:2px solid #107a2f; outline-offset:2px; }
  .scw-top{ display:flex; align-items:center; justify-content:space-between; padding:12px 14px 0; }
  .scw-tag{ display:inline-flex; align-items:center; gap:5px; font-family:var(--font-mono); font-size:9px; letter-spacing:.06em; text-transform:uppercase; color:var(--success); font-weight:700; }
  .scw-tag .ic{ width:12px; height:12px; flex:none; }
  .scw-zoom{ width:14px; height:14px; color:var(--fg-3); flex:none; }
  .scw-score{ display:flex; align-items:flex-end; gap:7px; padding:7px 14px 13px; }
  .scw-score .big{ font-family:var(--font-mono); font-weight:700; font-size:46px; line-height:.78; color:var(--teal); letter-spacing:-0.03em; }
  .scw-score .max{ font-family:var(--font-mono); font-size:14px; color:var(--fg-3); padding-bottom:5px; }
  .scw-score .lab{ font-family:var(--font-mono); font-size:8.5px; letter-spacing:.1em; text-transform:uppercase; color:var(--fg-3); margin-left:auto; padding-bottom:6px; text-align:right; line-height:1.35; }
  .scw-skills{ display:grid; grid-template-columns:repeat(4,1fr); gap:3px; padding:14px 8px 15px; border-top:1px solid var(--line-soft); }
  .sk{ display:flex; flex-direction:column; align-items:center; gap:7px; }
  .sk .ring{ width:43px; height:43px; border-radius:50%; border:2.5px solid var(--cream-dark); display:grid; place-items:center; font-family:var(--font-mono); font-weight:700; font-size:14px; color:var(--teal); letter-spacing:-0.01em; }
  .sk small{ font-family:var(--font-mono); font-size:8px; letter-spacing:.01em; color:var(--fg-3); }
  .ring.sk-l{ border-color:#1D3362; }
  .ring.sk-r{ border-color:#C4D600; }
  .ring.sk-s{ border-color:#6E7376; }
  .ring.sk-w{ border-color:#A2007A; }
  @media(max-width:520px){ .sk .ring{ width:36px; height:36px; font-size:12px; } .sk small{ font-size:7px; } .scw-skills{ padding:12px 3px 13px; gap:1px; } }
  .scw-foot{ display:flex; align-items:center; justify-content:space-between; gap:8px; margin-top:auto; padding:11px 14px; border-top:1px solid var(--line-soft); font-family:var(--font-mono); font-size:10.5px; color:var(--fg-3); }
  .scw-foot b{ color:var(--teal); font-weight:600; }
  .scw-foot .verify{ display:inline-flex; align-items:center; gap:4px; color:#107a2f; font-weight:600; }
  .scw-foot .verify .ic{ width:11px; height:11px; }
  @media(max-width:920px){ .scwall{ grid-template-columns:repeat(2,1fr); } }
  @media(max-width:520px){ .proofhd .pstats{ width:100%; } .pstat{ flex:1; min-width:0; } }
  .lightbox{ position:fixed; inset:0; z-index:100; background:rgba(6,30,35,.93); display:none; align-items:center; justify-content:center; padding:20px; cursor:zoom-out; }
  .lightbox.open{ display:flex; }
  .lightbox img{ max-width:min(640px,94vw); max-height:94vh; border-radius:8px; box-shadow:0 30px 80px -20px rgba(0,0,0,.7); }

  /* —— RESULTS · video showcase (real students, now abroad) —— */
  .sec-hd p b{ color:var(--teal); font-weight:600; }
  .vids{ display:grid; gap:16px; margin-top:36px; }
  .vid{ position:relative; margin:0; border-radius:18px; overflow:hidden; aspect-ratio:7/8;
    border:1px solid var(--line); background:#0d3f48; box-shadow:var(--shadow-card); cursor:pointer;
    transition:transform .28s var(--ease-out), box-shadow .3s var(--ease-out); }
  .vid:hover{ transform:translateY(-5px); box-shadow:var(--shadow-lift); }
  .vid:focus-visible{ outline:2px solid #107a2f; outline-offset:3px; }
  .vplayer{ position:absolute; inset:0; width:100%; height:100%; object-fit:cover; object-position:top center; background:#0d3f48; z-index:0; }
  /* layered teal treatment — vignette + top/bottom scrims knock back the busy frame + watermark and unify the three sources */
  .vid::after{ content:""; position:absolute; inset:0; z-index:1; transition:opacity .3s;
    background:
      linear-gradient(rgba(6,30,35,.30), rgba(6,30,35,.30)),
      radial-gradient(135% 92% at 50% 37%, transparent 36%, rgba(6,30,35,.68)),
      linear-gradient(to bottom, rgba(6,30,35,.88) 0%, rgba(6,30,35,.34) 14%, transparent 30%),
      linear-gradient(to top, rgba(6,30,35,.9) 2%, rgba(6,30,35,.14) 42%, transparent 60%); }
  .vid .play{ position:absolute; left:0; right:0; top:46%; margin:0 auto; transform:translateY(-50%);
    width:54px; height:54px; border-radius:50%; background:rgba(255,255,255,.94); z-index:2;
    display:grid; place-items:center; box-shadow:0 14px 32px -10px rgba(0,0,0,.55);
    transition:transform .25s var(--ease-spring); }
  .vid:hover .play{ transform:translateY(-50%) scale(1.1); }
  .vid .play svg{ width:18px; height:18px; fill:var(--teal); margin-left:3px; }
  .vid .vloc{ position:absolute; top:13px; right:13px; z-index:2; display:inline-flex; align-items:center; gap:6px;
    font-family:var(--font-mono); font-size:10px; font-weight:600; letter-spacing:.07em; text-transform:uppercase; color:#fff;
    background:rgba(6,30,35,.4); border:1px solid rgba(255,255,255,.18); border-radius:999px; padding:5px 10px;
    -webkit-backdrop-filter:blur(6px); backdrop-filter:blur(6px); }
  .vid .vloc .ic{ width:11px; height:11px; color:var(--gold-light); stroke-width:2.4; flex:none; }
  .vid .cap{ position:absolute; left:16px; right:16px; bottom:15px; z-index:2; color:#fff; }
  .vid .cap .nm{ display:block; font-family:var(--font-sans); font-weight:700; font-size:16px; letter-spacing:-0.01em; line-height:1.15; }
  .vid .cap .uni{ display:flex; align-items:center; gap:8px; margin-top:6px; font-family:var(--font-mono); font-size:11px; color:rgba(247,245,240,.82); }
  .vid .cap .uni::before{ content:""; width:14px; height:1px; background:var(--gold-light); flex:none; }
  .vid .play, .vid .cap, .vid .vloc{ transition:opacity .3s; }
  .vid.playing::after, .vid.playing .play, .vid.playing .cap, .vid.playing .vloc{ opacity:0; pointer-events:none; }
  .vid.playing .vplayer{ z-index:3; }

  /* —— BOOKING —— */
  .booking{ display:grid; gap:16px; margin-top:34px; }
  .urg{ background:var(--white); border:1px solid var(--line); border-radius:18px; padding:24px; box-shadow:var(--shadow-card); }
  .urg .lab{ font-family:var(--font-mono); font-size:11px; letter-spacing:.12em; text-transform:uppercase; color:var(--fg-3); }
  .cd{ display:flex; gap:8px; margin-top:14px; }
  .cd-u{ flex:1; text-align:center; background:var(--teal-950); border-radius:10px; padding:13px 4px; }
  .cd-u b{ display:block; font-family:var(--font-mono); font-weight:700; font-size:26px; color:#fff; line-height:1; }
  .cd-u small{ font-family:var(--font-mono); font-size:8.5px; letter-spacing:.1em; text-transform:uppercase; color:var(--gold-light); margin-top:6px; display:block; }
  .seats{ margin-top:22px; }
  .seats .t{ display:flex; justify-content:space-between; font-family:var(--font-mono); font-size:12.5px; color:var(--fg-2); margin-bottom:8px; }
  .seats .t b{ color:var(--teal); }
  .seatbar{ height:9px; border-radius:999px; background:rgba(14,72,82,0.10); overflow:hidden; }
  .seatfill{ display:block; height:100%; width:0; background:linear-gradient(90deg,#107a2f,#107a2f); border-radius:999px; box-shadow:0 0 10px -1px rgba(251,189,41,.5); transition:width 1.3s var(--ease-out) .2s; }
  .seats small{ font-family:var(--font-mono); font-size:11px; color:var(--fg-3); margin-top:9px; display:block; }

  /* quiz */
  .quiz{ margin-top:18px; padding-top:18px; border-top:1px dashed var(--line); }
  .quiz .ql{ font-size:13.5px; font-weight:600; color:var(--teal); margin-bottom:12px; display:flex; align-items:center; gap:8px; }
  .quiz .ql .ic{ width:16px; height:16px; color:#107a2f; }
  .qstep{ margin-bottom:12px; } .qstep .qq{ font-size:12px; color:var(--fg-3); margin-bottom:7px; font-family:var(--font-mono); letter-spacing:.04em; }
  .qopts{ display:flex; flex-wrap:wrap; gap:7px; }
  .qopt{ font-family:var(--font-sans); font-size:13px; font-weight:600; color:var(--teal); background:var(--white);
    border:1px solid var(--line); border-radius:999px; padding:8px 14px; cursor:pointer; transition:transform .15s var(--ease-spring), background .2s, border-color .2s; }
  .qopt:hover{ border-color:#107a2f; }
  .qopt.sel{ background:#107a2f; border-color:#107a2f; color:var(--teal-dark); transform:translateY(-1px); }
  .qout{ display:none; margin-top:14px; padding:14px 16px; background:var(--gold-soft); border-radius:12px; font-size:13.5px; color:var(--teal-dark); line-height:1.5; }
  .qout.show{ display:block; } .qout b{ color:var(--teal); }

  /* offer card */
  .offer{ background:var(--white); border:1px solid var(--line); border-radius:18px; box-shadow:var(--shadow-lift); padding:28px; position:relative; }
  .offer .flag{ font-family:var(--font-mono); font-size:11px; letter-spacing:.08em; text-transform:uppercase; color:#107a2f; }
  .offer .pr{ display:flex; align-items:baseline; gap:11px; margin:12px 0 3px; font-family:var(--font-mono); }
  .offer .pr b{ font-size:48px; font-weight:700; color:var(--teal); letter-spacing:-0.03em; line-height:1; }
  .offer .pr s{ font-size:19px; color:var(--fg-3); }
  .offer .pr-sub{ font-family:var(--font-mono); font-size:12px; color:var(--fg-3); margin-bottom:20px; }
  .offer ul{ list-style:none; padding:0; margin:0; display:grid; gap:11px; }
  .offer li{ display:flex; gap:10px; font-size:14.5px; color:var(--fg-2); line-height:1.45; }
  .offer li .ic{ width:17px; height:17px; color:#107a2f; margin-top:2px; stroke-width:2.4; }
  .offer li b{ color:var(--teal); }
  .bump{ margin-top:20px; border:1px dashed #107a2f; border-radius:12px; padding:15px; cursor:pointer; display:flex; gap:12px; align-items:flex-start; transition:background .2s; position:relative; }
  .bump:hover{ background:var(--gold-soft); }
  .bump input{ position:absolute; opacity:0; pointer-events:none; }
  .bump .box{ width:22px; height:22px; border-radius:6px; border:2px solid #107a2f; background:var(--white); display:grid; place-items:center; flex:none; margin-top:1px; }
  .bump .box .ic{ width:13px; height:13px; color:#fff; stroke-width:3; opacity:0; }
  .bump input:checked + .box{ background:#107a2f; } .bump input:checked + .box .ic{ opacity:1; }
  .bump .bt{ font-size:13px; color:var(--teal-dark); line-height:1.5; } .bump .bt b{ color:var(--teal); }
  .bump .bt .add{ font-family:var(--font-mono); color:#107a2f; font-weight:700; }
  .nowpay{ display:flex; align-items:baseline; justify-content:space-between; margin-top:20px; padding-top:16px; border-top:1px solid var(--line); font-family:var(--font-mono); font-size:13px; color:var(--fg-3); }
  .nowpay b{ font-size:20px; color:var(--teal); font-weight:700; }
  .offer .btn{ margin-top:16px; }
  .trust-chips{ display:flex; flex-wrap:wrap; gap:10px 16px; justify-content:center; margin-top:16px; }
  .trust-chips span{ display:inline-flex; align-items:center; gap:6px; font-size:12px; color:var(--fg-3); }
  .trust-chips .ic{ width:14px; height:14px; color:var(--success); }

  /* —— BOOKING · "the live ticket" — single focal enrollment card —— */
  .ticket{ max-width:600px; margin:34px auto 0; }
  .tk-top{ display:flex; align-items:center; justify-content:space-between; gap:12px; }
  .tk-kind{ font-family:var(--font-mono); font-size:11px; font-weight:600; letter-spacing:.14em; text-transform:uppercase; color:#107a2f; }
  .tk-pricerow{ display:flex; align-items:center; justify-content:space-between; gap:14px; flex-wrap:wrap; margin-bottom:9px; }
  .tk-pricerow .pr{ margin:0; }
  .tk-trust{ display:inline-flex; align-items:center; gap:9px; text-decoration:none; background:var(--white); border:1px solid var(--line); border-radius:13px; padding:7px 12px; transition:border-color .18s var(--ease-out), box-shadow .18s var(--ease-out); }
  .tk-trust:hover{ border-color:var(--border-gold); box-shadow:var(--shadow-card); }
  .tk-trust .gbadge-g{ width:22px; height:22px; flex:none; }
  .tk-trust-b{ display:flex; flex-direction:column; line-height:1.12; }
  .tk-trust-top{ display:flex; align-items:center; gap:6px; }
  .tk-trust-top b{ font-size:15px; color:var(--teal); font-weight:800; letter-spacing:-0.01em; }
  .tk-trust-top .gstars{ font-size:10px; color:#FBBC04; letter-spacing:.5px; }
  .tk-trust small{ font-size:10.5px; color:var(--fg-3); }
  .tk-when{ display:grid; gap:11px; margin-top:18px; }
  .tk-row{ display:flex; align-items:center; gap:13px; }
  .tk-ico{ width:42px; height:42px; border-radius:12px; background:var(--paper-card); border:1px solid var(--line); display:grid; place-items:center; flex:none; }
  .tk-ico .ic{ width:19px; height:19px; color:var(--teal); }
  .tk-row .l{ font-family:var(--font-sans); font-weight:700; font-size:15px; color:var(--teal); line-height:1.2; letter-spacing:-0.01em; }
  .tk-row .s{ font-size:13px; color:var(--fg-2); margin-top:2px; }
  .ticket ul{ border-top:1px solid var(--line); margin-top:20px; padding-top:20px; }
  .ticket .seats{ margin-top:20px; }
  .tk-pay{ border-top:1px solid var(--line); margin-top:22px; padding-top:22px; }
  .tk-guar{ display:flex; align-items:center; justify-content:center; gap:8px; margin-top:15px; font-size:12.5px; color:var(--fg-3); }
  .tk-guar .ic{ width:15px; height:15px; color:var(--success); flex:none; }

  /* —— "what happens after you pay" — slim post-purchase rail —— */
  .postbook{ max-width:600px; margin:18px auto 0; }
  .pb-lab{ display:block; text-align:center; font-family:var(--font-mono); font-size:10.5px; letter-spacing:.12em; text-transform:uppercase; color:var(--fg-3); margin-bottom:14px; }
  .pb-steps{ list-style:none; margin:0; padding:0; display:grid; gap:12px; }
  .pb-steps li{ display:flex; align-items:center; gap:10px; font-size:12.5px; color:var(--fg-2); line-height:1.35; }
  .pb-n{ font-family:var(--font-mono); font-weight:700; font-size:11px; color:#107a2f; background:var(--gold-soft); border:1px solid var(--border-gold); width:24px; height:24px; border-radius:50%; display:grid; place-items:center; flex:none; }
  .pb-t b{ color:var(--teal); font-weight:700; }
  @media (min-width:680px){ .pb-steps{ grid-template-columns:repeat(3,1fr); gap:16px; } }

  /* —— FAQ — premium numbered accordion —— */
  .faq{ max-width:760px; margin:34px auto 0; border-top:1px solid var(--line); }
  details.q{ border-bottom:1px solid var(--line); }
  details.q summary{ list-style:none; cursor:pointer; padding:22px 2px; display:flex; gap:16px; align-items:baseline; }
  details.q summary::-webkit-details-marker{ display:none; }
  .qn{ font-family:var(--font-mono); font-size:13px; font-weight:600; color:#107a2f; flex:none; width:26px; }
  .qt{ flex:1; font-family:var(--font-sans); font-weight:700; color:var(--teal); font-size:17px; letter-spacing:-0.01em; line-height:1.3; }
  details.q summary::after{ content:"+"; font-family:var(--font-mono); color:#107a2f; font-weight:500; font-size:22px; line-height:1; flex:none; align-self:center; }
  details.q[open] summary::after{ content:"\2212"; }
  details.q summary:hover .qt{ color:var(--teal-light); }
  details.q .a{ padding:0 0 22px 42px; font-size:14.5px; color:var(--fg-2); line-height:1.65; max-width:62ch; }

  /* —— FINAL — contained dark card (matches hero/hook/mentor; the "no full teal-wash" brand rule) —— */
  .final{ text-align:center; }
  .final-card{ position:relative; overflow:hidden; background:var(--teal-950); color:var(--paper);
    border-radius:28px; padding:clamp(46px,7vw,82px) clamp(24px,5vw,56px);
    box-shadow:inset 0 1px 0 0 rgba(255,255,255,.05); }
  .final-card::before{ content:""; position:absolute; inset:0; pointer-events:none;
    background:radial-gradient(760px 420px at 50% -25%, rgba(251,189,41,.13), transparent 62%); }
  .final-card>*{ position:relative; }
  .final h2{ color:#fff; font-size:clamp(34px,5.6vw,56px); line-height:1.02; letter-spacing:-0.02em; }
  .final h2 em{ font-style:normal; color:#107a2f; }
  .final p{ color:rgba(247,245,240,.74); margin:20px auto 30px; max-width:46ch; font-size:16px; line-height:1.6; }
  .final .fmicro{ margin-top:18px; font-family:var(--font-mono); font-size:11.5px; color:rgba(247,245,240,.5); letter-spacing:.04em; }

  /* —— TRUST / FOOTER —— */
  .trust{ background:var(--white); border-top:1px solid var(--line); }
  .trust .inner{ padding:30px 22px; display:grid; gap:16px; text-align:center; }
  .trust .badges{ display:flex; flex-wrap:wrap; gap:10px 14px; justify-content:center; align-items:center; }
  .trust .badges .pay{ font-family:var(--font-mono); font-size:11px; color:var(--fg-2); background:var(--paper); border:1px solid var(--line-soft); padding:7px 12px; border-radius:6px; }
  .trust .badges .g{ display:inline-flex; align-items:center; gap:6px; font-size:13px; color:var(--fg-2); }
  .trust .badges .g .stars{ color:#107a2f; } .trust .badges .g b{ color:var(--teal); }
  .disc{ font-size:11.5px; color:var(--fg-3); max-width:70ch; margin:0 auto; line-height:1.6; }
  /* —— SITE FOOTER (structure & content matches /apply) —— */
  .site-footer{ background:var(--teal-950); color:var(--paper); }
  .site-footer .inner{ padding:64px 22px; }
  .ft-grid{ display:grid; grid-template-columns:1.5fr 1fr 1fr 1.3fr 1fr; gap:40px; }
  .ft-logo{ display:flex; align-items:center; gap:9px; margin-bottom:16px; }
  .ft-logo-mark{ width:32px; height:32px; border-radius:9px; background:#107a2f; color:var(--teal); display:flex; align-items:center; justify-content:center; font-weight:800; font-size:15px; }
  .ft-logo-word{ font-family:var(--font-sans); font-weight:700; font-size:18px; color:#fff; }
  .ft-logo-word b{ color:#107a2f; font-weight:700; }
  .ft-tag{ color:rgba(247,245,240,.5); font-size:13.5px; line-height:1.65; font-weight:500; max-width:30ch; }
